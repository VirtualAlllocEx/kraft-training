---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const categoryMap: Record<string, string> = {
  aufwaermen: 'Aufwärmen',
  passspiel: 'Passspiel',
  torabschluss: 'Torabschluss',
  spielform: 'Spielform',
  halle: 'Halle',
  kondition: 'Kondition',
};

export async function getStaticPaths() {
  const exercises = await getCollection('uebungen');
  const slugs = ['aufwaermen', 'passspiel', 'torabschluss', 'spielform', 'halle', 'kondition'];

  return slugs.map(slug => {
    const filtered = exercises
      .filter(e => e.data.category === slug)
      .sort((a, b) => {
        const orderDiff = (a.data.order ?? 0) - (b.data.order ?? 0);
        if (orderDiff !== 0) return orderDiff;
        return a.data.title.localeCompare(b.data.title, 'de');
      });

    return {
      params: { slug },
      props: { exercises: filtered },
    };
  });
}

const categoryDescriptions: Record<string, string> = {
  aufwaermen: 'Aufwärmübungen für das Fußballtraining: Koordination, Passformen, Technik.',
  passspiel: 'Passspiel-Übungen für Grundtechnik, Präzision und Spielaufbau im Fußballtraining.',
  torabschluss: 'Torabschluss-Übungen: Torschusstraining, Abschluss unter Druck, 1-Kontakt-Torschuss.',
  spielform: 'Spielformen im Fußballtraining: 1 gegen 1 bis 5 gegen 5, Umschaltspiel, Ballbesitz.',
  halle: 'Übungen für das Hallentraining im Winter: kompakt, hochintensiv, technikorientiert.',
  kondition: 'Konditions- und Ausdauerübungen für Fußballspieler.',
};

const { slug } = Astro.params;
const { exercises } = Astro.props;
const categoryName = categoryMap[slug!] || slug;
---

<Base title={categoryName} description={`${categoryDescriptions[slug!] || categoryName} ${exercises.length} Übungen zur Auswahl.`}>

  <div class="container-lg">
    <div class="exercise-header">
      <h1>{categoryName}</h1>
      <div class="exercise-meta">
        <span class="exercise-count">{exercises.length} {exercises.length === 1 ? 'Übung' : 'Übungen'}</span>
        <a href="/" class="back-link">&larr; ALLE KATEGORIEN</a>
      </div>
    </div>

    {exercises.length > 0 && (
      <div class="exercise-search">
        <input
          type="search"
          id="exerciseSearch"
          placeholder="Übung suchen…"
          aria-label="Übung suchen"
          autocomplete="off"
          spellcheck="false"
        />
        <p class="exercise-no-results" id="exerciseNoResults" hidden>Keine Treffer</p>
        <p id="searchResultCount" class="search-count" role="status" aria-live="polite" aria-atomic="true"></p>
      </div>
    )}

    {exercises.length === 0 ? (
      <div style="padding: 60px 0; text-align: center;">
        <p style="color: var(--text-muted); font-size: 18px;">
          Noch keine Übungen in dieser Kategorie.
        </p>
        <p style="color: var(--text-dim); margin-top: 10px;">
          Füge Übungen über den <a href="/admin/" class="link-bold" style="font-size: 16px;">Admin-Bereich</a> hinzu.
        </p>
      </div>
    ) : (
      <div class="exercise-grid">
        {exercises.map((exercise, idx) => (
          <div
            class="exercise-card"
            data-id={exercise.id}
            data-src={exercise.data.image}
            data-title={exercise.data.title}
            data-description={exercise.data.description ?? ''}
            data-video={exercise.data.videoUrl ?? ''}
            data-duration={exercise.data.duration ?? ''}
            data-players={exercise.data.playerCount ?? ''}
            data-index={idx}
            role="button"
            tabindex="0"
            aria-label={`${exercise.data.title} vergrößern`}
          >
            <img
              src={exercise.data.image}
              alt={exercise.data.title}
              loading={idx < 4 ? 'eager' : 'lazy'}
              decoding="async"
              width="600"
              height="450"
              fetchpriority={idx < 2 ? 'high' : 'auto'}
            />
            <div class="exercise-name">{exercise.data.title}</div>
            {(exercise.data.duration || exercise.data.playerCount) && (
              <div class="exercise-tags">
                {exercise.data.duration && <span class="exercise-tag">⏱ {exercise.data.duration}</span>}
                {exercise.data.playerCount && <span class="exercise-tag">👥 {exercise.data.playerCount}</span>}
              </div>
            )}
            <button
              type="button"
              class="exercise-plan-btn"
              data-id={exercise.id}
              data-add-label={`${exercise.data.title} zum Trainingsplan hinzufügen`}
              data-remove-label={`${exercise.data.title} aus dem Trainingsplan entfernen`}
              aria-label={`${exercise.data.title} zum Trainingsplan hinzufügen`}
              aria-pressed="false"
            >
              <span class="exercise-plan-btn-plus" aria-hidden="true">+</span>
              <span class="exercise-plan-btn-text">Plan</span>
              <span class="exercise-plan-btn-check" aria-hidden="true">✓</span>
            </button>
          </div>
        ))}
      </div>
    )}
  </div>

  <script is:inline>
    (function () {
      var cards = document.querySelectorAll('.exercise-card[data-src]');
      if (!cards.length) return;

      var images = [];
      for (var i = 0; i < cards.length; i++) {
        images.push({
          id: cards[i].getAttribute('data-id') || '',
          src: cards[i].getAttribute('data-src'),
          title: cards[i].getAttribute('data-title'),
          description: cards[i].getAttribute('data-description') || '',
          video: cards[i].getAttribute('data-video') || '',
          duration: cards[i].getAttribute('data-duration') || '',
          players: cards[i].getAttribute('data-players') || ''
        });
      }

      // CRITICAL FIX: stash images for Base.astro to pick up if it hasn't initialized yet
      if (typeof window.setLbImages === 'function') {
        window.setLbImages(images);
      } else {
        window._pendingLbImages = images;
      }

      // Open the lightbox with only the currently visible (not filtered-out)
      // cards, so prev/next never cycles through hidden exercises
      function openCardLightbox(card) {
        if (card.dataset.broken === 'true') return;
        var visibleImages = [];
        var visibleIdx = -1;
        for (var v = 0; v < cards.length; v++) {
          if (cards[v].style.display === 'none') continue;
          if (cards[v] === card) visibleIdx = visibleImages.length;
          visibleImages.push(images[v]);
        }
        if (visibleIdx === -1) return;
        if (typeof window.setLbImages === 'function') window.setLbImages(visibleImages);
        if (typeof window.setLbIndex === 'function') window.setLbIndex(visibleIdx);
        if (typeof window.showLbImage === 'function') window.showLbImage(visibleIdx);
      }

      for (var j = 0; j < cards.length; j++) {
        (function (card) {
          card.addEventListener('click', function (e) {
            if (this.dataset.broken === 'true') return;
            if (e.target.closest('.exercise-plan-btn')) return; // let the plan button handle it
            openCardLightbox(card);
          });
          card.addEventListener('keydown', function (e) {
            if (e.target.closest('.exercise-plan-btn')) return; // let the plan button handle it
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              openCardLightbox(card);
            }
          });
        })(cards[j]);
      }

      // Image load/error handling
      var imgs = document.querySelectorAll('.exercise-card img');

      function markImageBroken(img) {
        if (img.dataset.broken === 'true') return;
        img.classList.add('loaded');
        img.dataset.broken = 'true';
        var brokenCard = img.closest('.exercise-card');
        if (brokenCard) {
          brokenCard.dataset.broken = 'true';
          brokenCard.setAttribute('aria-disabled', 'true');
        }
        img.style.display = 'none';
        var placeholder = document.createElement('div');
        placeholder.setAttribute('role', 'img');
        placeholder.setAttribute('aria-label', img.alt + ' — Bild nicht verfügbar');
        placeholder.style.cssText = 'width:100%;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;background:#2a2a2a;color:#c0c0c0;font-size:13px;letter-spacing:0.5px;';
        placeholder.textContent = 'Bild nicht verfügbar';
        img.parentNode.insertBefore(placeholder, img);
      }

      for (var k = 0; k < imgs.length; k++) {
        if (imgs[k].complete) {
          if (imgs[k].naturalWidth === 0) {
            // Cached broken image: complete is true but nothing decoded
            markImageBroken(imgs[k]);
          } else {
            imgs[k].classList.add('loaded');
          }
        } else {
          imgs[k].addEventListener('load', function () {
            this.classList.add('loaded');
          });
          imgs[k].addEventListener('error', function () {
            markImageBroken(this);
          });
        }
      }
    })();
  </script>

  <script is:inline>
    (function () {
      var input = document.getElementById('exerciseSearch');
      var noResults = document.getElementById('exerciseNoResults');
      var grid = document.querySelector('.exercise-grid');
      if (!input || !grid) return;

      var cards = grid.querySelectorAll('.exercise-card');
      var countEl = document.getElementById('searchResultCount');

      // Fold umlauts/diacritics so "ubung" matches "Übung", "strasse" matches "Straße"
      function normalize(s) {
        s = (s || '').toLowerCase();
        if (s.normalize) {
          s = s.normalize('NFD').replace(/[̀-ͯ]/g, '');
        }
        return s.replace(/ß/g, 'ss');
      }

      // Precompute normalized titles once
      var normalizedTitles = [];
      for (var i = 0; i < cards.length; i++) {
        normalizedTitles[i] = normalize(cards[i].getAttribute('data-title'));
      }

      input.addEventListener('input', function () {
        var query = normalize(input.value.trim());
        var visible = 0;

        for (var i = 0; i < cards.length; i++) {
          var match = query === '' || normalizedTitles[i].indexOf(query) !== -1;
          cards[i].style.display = match ? '' : 'none';
          if (match) visible++;
        }

        if (noResults) noResults.hidden = visible > 0;
        if (countEl) {
          countEl.textContent = query
            ? visible + ' von ' + cards.length + ' Übungen'
            : '';
        }
      });

      // Prefill from ?suche= — used by the homepage global search links
      try {
        var pre = new URLSearchParams(window.location.search).get('suche');
        if (pre) {
          input.value = pre;
          input.dispatchEvent(new Event('input'));
        }
      } catch (e) { /* older browsers: just show the unfiltered list */ }
    })();
  </script>

  <script is:inline>
    (function () {
      var STORAGE_KEY = 'kraft:plan:v1';

      function readPlan() {
        try {
          var raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
          if (Array.isArray(raw)) return raw;
          if (raw && Array.isArray(raw.ids)) return raw.ids; // future format
        } catch (e) {}
        return [];
      }

      function writePlan(ids) {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(ids)); } catch (e) {}
      }

      function updateBtnState(card, inPlan) {
        var btn = card.querySelector('.exercise-plan-btn');
        if (!btn) return;
        card.classList.toggle('in-plan', inPlan);
        btn.setAttribute('aria-pressed', inPlan ? 'true' : 'false');
        btn.setAttribute('aria-label',
          inPlan ? btn.getAttribute('data-remove-label') || 'Aus dem Trainingsplan entfernen'
                 : btn.getAttribute('data-add-label') || 'Zum Trainingsplan hinzufügen');
      }

      function syncAllCards() {
        var plan = readPlan();
        document.querySelectorAll('.exercise-card').forEach(function (card) {
          var btn = card.querySelector('.exercise-plan-btn');
          if (!btn) return;
          var id = btn.getAttribute('data-id');
          updateBtnState(card, plan.indexOf(id) !== -1);
        });
      }

      // Initial state
      syncAllCards();

      // Keep cards in sync when the plan changes elsewhere (e.g. lightbox button)
      window.addEventListener('plan-changed', syncAllCards);

      // Button click handling (delegated)
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.exercise-plan-btn');
        if (!btn) return;
        e.stopPropagation();
        e.preventDefault();
        var id = btn.getAttribute('data-id');
        var card = btn.closest('.exercise-card');
        var current = readPlan();
        var idx = current.indexOf(id);
        var nowIn;
        if (idx === -1) {
          current.push(id);
          nowIn = true;
        } else {
          current.splice(idx, 1);
          nowIn = false;
        }
        writePlan(current);
        if (card) updateBtnState(card, nowIn);
        window.dispatchEvent(new CustomEvent('plan-changed'));
        if (window.updatePlanBadge) window.updatePlanBadge();
      });
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": categoryName,
    "numberOfItems": exercises.length,
    "itemListElement": exercises.map((ex, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": ex.data.title,
      "image": new URL(ex.data.image, Astro.site).href
    }))
  })}></script>

</Base>
