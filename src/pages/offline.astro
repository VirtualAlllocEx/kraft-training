---
import Base from '../layouts/Base.astro';
---
<Base title="Offline" description="Du bist offline">
  <div class="container-lg" style="padding: 120px 20px 60px; text-align: center;">
    <h1>Offline</h1>
    <p style="margin-top: 20px; color: var(--text-muted);">
      Du bist gerade offline. Sobald wieder Verbindung besteht, kannst du weiterhin Übungen ansehen, die du bereits geöffnet hast.
    </p>
    <a href="/" class="link-bold" style="margin-top: 30px; display: inline-block;">Zur Startseite</a>
  </div>
</Base>
