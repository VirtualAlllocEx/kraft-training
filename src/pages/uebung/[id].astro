---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const categoryMap: Record<string, string> = {
  aufwaermen: 'Aufwärmen',
  passspiel: 'Passspiel',
  torabschluss: 'Torabschluss',
  spielform: 'Spielform',
  halle: 'Halle',
  kondition: 'Kondition',
};

export async function getStaticPaths() {
  const exercises = await getCollection('uebungen');
  return exercises.map(ex => ({
    params: { id: ex.id },
    props: { exercise: ex },
  }));
}

const { exercise } = Astro.props;
const data = exercise.data;
const categoryName = categoryMap[data.category];
const canonical = new URL(`/uebung/${exercise.id}/`, Astro.site).href;

// <-escaping keeps a literal "</script>" in exercise data from
// terminating the JSON-LD script tag early (same guard as index.astro)
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ExercisePlan',
  name: data.title,
  image: new URL(data.image, Astro.site).href,
  description: data.description || `${categoryName}-Übung`,
  exerciseType: categoryName,
}).replace(/</g, '\\u003c');
---

<Base title={data.title} description={data.description || `${categoryName}-Übung: ${data.title}`}>
  <div class="container-lg" style="padding-top:100px;">
    <div style="margin-bottom: 20px;">
      <a href={`/kategorie/${data.category}/`} class="back-link">
        &larr; ZURÜCK ZU {categoryName.toUpperCase()}
      </a>
    </div>

    <article class="exercise-detail">
      <div class="exercise-detail-image">
        <img src={data.image} alt={data.title} loading="eager" width="1200" height="900" />
      </div>

      <div class="exercise-detail-body">
        <h1>{data.title}</h1>
        <p class="exercise-detail-category">{categoryName}</p>

        {(data.duration || data.playerCount) && (
          <div class="exercise-tags" style="margin: 20px 0;">
            {data.duration && <span class="exercise-tag">⏱ {data.duration}</span>}
            {data.playerCount && <span class="exercise-tag">👥 {data.playerCount}</span>}
          </div>
        )}

        {data.description && (
          <div class="exercise-detail-description">
            <p>{data.description}</p>
          </div>
        )}

        {data.videoUrl && (
          <p style="margin-top: 24px;">
            <a href={data.videoUrl} class="link-bold" target="_blank" rel="noopener noreferrer">
              ▶ Video ansehen
            </a>
          </p>
        )}

        <div class="exercise-detail-actions" style="margin-top: 40px; display: flex; gap: 12px; flex-wrap: wrap;">
          <button type="button" class="btn-add-to-plan" data-id={exercise.id} aria-pressed="false">+ Zum Trainingsplan hinzufügen</button>
          <button type="button" class="btn-share" data-url={canonical} data-title={data.title}>🔗 Link teilen</button>
          <button type="button" class="btn-print">🖨 Drucken</button>
        </div>

        <div class="exercise-detail-share" id="shareStatus" role="status" aria-live="polite"></div>

        <p class="exercise-detail-hint">
          Hinweis: Der Link zu dieser Seite ändert sich, wenn die Übung umbenannt wird.
        </p>
      </div>
    </article>
  </div>

  <script type="application/ld+json" set:html={jsonLd}></script>

  <script is:inline>
    (function() {
      var addBtn = document.querySelector('.btn-add-to-plan');
      var shareBtn = document.querySelector('.btn-share');
      var printBtn = document.querySelector('.btn-print');
      var status = document.getElementById('shareStatus');
      var STORAGE_KEY = 'kraft:plan:v1';
      var statusTimer = null;

      function setStatus(msg, persist) {
        if (!status) return;
        // Reset the hide timer on every message — otherwise a timer from an
        // earlier click wipes a newer message almost immediately
        if (statusTimer) { clearTimeout(statusTimer); statusTimer = null; }
        status.textContent = msg;
        if (!persist) {
          statusTimer = setTimeout(function() {
            status.textContent = '';
            statusTimer = null;
          }, 3000);
        }
      }

      // Same storage handling as the Base layout: the stored value may be a
      // plain array of ids or an object ({ids: []} / {current: []} formats).
      // Reading only arrays and writing arrays back would clobber the object.
      function readPlan() {
        try {
          var raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
          if (Array.isArray(raw)) return raw;
          if (raw && Array.isArray(raw.ids)) return raw.ids;
          if (raw && Array.isArray(raw.current)) return raw.current;
        } catch (e) {}
        return [];
      }

      function writePlan(ids) {
        var raw = null;
        // Parsed separately: a corrupt stored value must not prevent the
        // write — it just means we start over with a plain array
        try { raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null'); } catch (e) {}
        try {
          if (raw && typeof raw === 'object' && !Array.isArray(raw)) {
            if (Array.isArray(raw.ids)) raw.ids = ids;
            else raw.current = ids;
            localStorage.setItem(STORAGE_KEY, JSON.stringify(raw));
          } else {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
          }
        } catch (e) {}
      }

      function syncAddBtn() {
        if (!addBtn) return;
        var id = addBtn.getAttribute('data-id');
        var inPlan = readPlan().indexOf(id) !== -1;
        addBtn.classList.toggle('in-plan', inPlan);
        addBtn.textContent = inPlan ? '✓ Bereits im Plan' : '+ Zum Trainingsplan hinzufügen';
        addBtn.setAttribute('aria-pressed', inPlan ? 'true' : 'false');
        addBtn.setAttribute('aria-label', inPlan
          ? 'Aus dem Trainingsplan entfernen'
          : 'Zum Trainingsplan hinzufügen');
      }

      function countLabel(n) {
        return n + ' Übung' + (n === 1 ? '' : 'en');
      }

      if (addBtn) {
        addBtn.addEventListener('click', function() {
          var id = this.getAttribute('data-id');
          var ids = readPlan();
          var idx = ids.indexOf(id);
          if (idx === -1) {
            ids.push(id);
            writePlan(ids);
            setStatus('✓ Zum Trainingsplan hinzugefügt (' + countLabel(ids.length) + ')');
          } else {
            ids.splice(idx, 1);
            writePlan(ids);
            setStatus('Aus dem Trainingsplan entfernt' +
              (ids.length > 0 ? ' (' + countLabel(ids.length) + ')' : ''));
          }
          syncAddBtn();
          // Lets the header badge (Base layout) pick up the change
          window.dispatchEvent(new CustomEvent('plan-changed'));
        });

        syncAddBtn();
        window.addEventListener('plan-changed', syncAddBtn);
        // bfcache restore (back button after editing the plan on /plan/)
        window.addEventListener('pageshow', syncAddBtn);
        // plan changed in another tab
        window.addEventListener('storage', function(e) {
          if (e.key === STORAGE_KEY) {
            syncAddBtn();
            if (window.updatePlanBadge) window.updatePlanBadge();
          }
        });
      }

      // Last-resort copy for browsers without navigator.clipboard
      // (e.g. older WebViews, http:// contexts)
      function legacyCopy(text) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.cssText = 'position:fixed;top:-1000px;left:-1000px;opacity:0;';
        document.body.appendChild(ta);
        ta.select();
        try { ta.setSelectionRange(0, text.length); } catch (e) {}
        var ok = false;
        try { ok = document.execCommand('copy'); } catch (e) {}
        document.body.removeChild(ta);
        return ok;
      }

      if (shareBtn) {
        shareBtn.addEventListener('click', async function() {
          var url = this.getAttribute('data-url');
          var title = this.getAttribute('data-title');
          if (navigator.share) {
            try {
              await navigator.share({ title: title, url: url });
              return;
            } catch (e) {
              // User closed the share sheet — don't copy behind their back
              if (e && e.name === 'AbortError') return;
            }
          }
          if (navigator.clipboard && navigator.clipboard.writeText) {
            try {
              await navigator.clipboard.writeText(url);
              setStatus('✓ Link kopiert');
              return;
            } catch (e) {}
          }
          if (legacyCopy(url)) {
            setStatus('✓ Link kopiert');
          } else {
            // Nothing to copy with — show the link itself and keep it
            // visible (no 3s auto-hide) so it can be selected by hand
            setStatus('Link zum Kopieren: ' + url, true);
          }
        });
      }

      if (printBtn) {
        printBtn.addEventListener('click', function() { window.print(); });
      }

      // Show a placeholder if the exercise image fails to load
      var detailImg = document.querySelector('.exercise-detail-image img');
      if (detailImg) {
        var showImageFallback = function() {
          if (detailImg.dataset.broken === 'true') return;
          detailImg.dataset.broken = 'true';
          detailImg.style.display = 'none';
          var placeholder = document.createElement('div');
          placeholder.setAttribute('role', 'img');
          placeholder.setAttribute('aria-label', detailImg.alt + ' — Bild nicht verfügbar');
          placeholder.style.cssText = 'width:100%;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;background:#2a2a2a;color:#c0c0c0;font-size:14px;';
          placeholder.textContent = 'Bild nicht verfügbar';
          detailImg.parentNode.insertBefore(placeholder, detailImg);
        };
        if (detailImg.complete && detailImg.naturalWidth === 0) {
          // Image already failed before this script ran (loading="eager")
          showImageFallback();
        } else {
          detailImg.addEventListener('error', showImageFallback);
        }
      }
    })();
  </script>
</Base>

<style>
  .exercise-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .exercise-detail-image img {
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    background: #f5f5f5;
    padding: 8px;
  }
  .exercise-detail-body h1 {
    font-size: clamp(28px, 5vw, 48px);
    margin-bottom: 8px;
  }
  .exercise-detail-category {
    color: var(--text-muted);
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .exercise-detail-description {
    margin-top: 24px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text);
    white-space: pre-wrap;
  }
  .btn-add-to-plan, .btn-share, .btn-print {
    padding: 12px 20px;
    min-height: 44px;
    background: var(--bg-card);
    color: var(--text);
    border: 1px solid var(--border);
    font-family: Inter, sans-serif;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  @media (hover: hover) {
    .btn-add-to-plan:hover, .btn-share:hover, .btn-print:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
  }
  .btn-add-to-plan { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  @media (hover: hover) {
    .btn-add-to-plan:hover { opacity: 0.9; color: var(--bg); }
  }
  /* Exercise is already in the plan: quieter look, click removes it */
  .btn-add-to-plan.in-plan {
    background: var(--bg-card);
    color: var(--accent);
    border-color: var(--accent);
  }
  @media (hover: hover) {
    .btn-add-to-plan.in-plan:hover { opacity: 1; color: var(--accent); }
  }
  .exercise-detail-share {
    margin-top: 16px;
    color: var(--accent);
    font-size: 13px;
    letter-spacing: 0.5px;
    min-height: 20px;
    /* The clipboard-less fallback prints the full URL here: it must wrap
       on small screens and stay selectable for manual copying */
    overflow-wrap: anywhere;
    -webkit-user-select: text;
    user-select: text;
  }
  .exercise-detail-hint {
    margin-top: 24px;
    color: var(--text-dim);
    font-size: 12px;
    letter-spacing: 0.3px;
  }

  @media (max-width: 800px) {
    .exercise-detail {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media print {
    .exercise-detail-actions,
    .exercise-detail-share,
    .exercise-detail-hint,
    .back-link {
      display: none !important;
    }
    /* The 100px screen offset (fixed header) just wastes paper */
    .container-lg {
      padding-top: 0 !important;
    }
    .exercise-detail {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    /* Dark-theme colors are unreadable on paper: h1 prints accent
       yellow-green and body text prints white without these */
    .exercise-detail-body h1 {
      color: #000;
    }
    .exercise-detail-category {
      color: #333;
    }
    .exercise-detail-description {
      color: #000;
    }
    .exercise-detail-image img {
      background: #fff;
      border: 1px solid #ccc;
      /* Cap the image so title + image + description fit on one page */
      max-height: 12cm;
      width: auto;
      max-width: 100%;
    }
    /* global.css hides tag chips in print (grid pages); on the detail
       page duration/players belong on the printout */
    .exercise-detail .exercise-tags {
      display: flex !important;
      padding: 0;
    }
    .exercise-detail .exercise-tag {
      display: inline-flex !important;
      color: #333 !important;
      border-color: #ccc !important;
      background: #fff !important;
    }
  }
</style>
