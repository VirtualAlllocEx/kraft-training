---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const categoryInfo = [
  { slug: 'aufwaermen', name: 'Aufwärmen' },
  { slug: 'passspiel', name: 'Passspiel' },
  { slug: 'torabschluss', name: 'Torabschluss' },
  { slug: 'spielform', name: 'Spielform' },
  { slug: 'halle', name: 'Halle' },
  { slug: 'kondition', name: 'Kondition' },
];

const allExercises = await getCollection('uebungen');

const groups = categoryInfo
  .map(cat => ({
    ...cat,
    exercises: allExercises
      .filter(e => e.data.category === cat.slug)
      .sort((a, b) =>
        ((a.data.order ?? 0) - (b.data.order ?? 0)) ||
        a.data.title.localeCompare(b.data.title, 'de')),
  }))
  .filter(g => g.exercises.length > 0);
---

<Base title="Trainingsplan" description="Trainingsplan für das Fußballtraining zusammenstellen: Übungen aus allen Kategorien auswählen und als druckfertigen Plan ausgeben.">

  <div class="container-lg">
    <div class="exercise-header">
      <h1>Trainingsplan</h1>
      <div class="exercise-meta">
        <span class="exercise-count">Übungen auswählen und ausgewählte Übungen drucken</span>
        <a href="/" class="back-link">&larr; ALLE KATEGORIEN</a>
      </div>
    </div>

    <div class="plan-controls">
      <div class="plan-buttons">
        <button type="button" id="planPrint" class="plan-btn plan-btn--primary">Ausgewählte drucken</button>
        <button type="button" id="planSelectAll" class="plan-btn">Alle auswählen</button>
        <button type="button" id="planClear" class="plan-btn">Auswahl leeren</button>
      </div>
      <p class="plan-count" id="planCount" aria-live="polite">0 Übungen ausgewählt</p>
    </div>

    {groups.length === 0 ? (
      <div class="plan-empty">
        <p>Noch keine Übungen vorhanden.</p>
        <p>Sobald Übungen angelegt sind, können sie hier für den Trainingsplan ausgewählt werden.</p>
      </div>
    ) : groups.map(group => (
      <section class="plan-group">
        <h2 class="plan-group-title">{group.name}</h2>
        <div class="plan-list">
          {group.exercises.map(exercise => (
            <label class="plan-item">
              <input type="checkbox" class="plan-check" data-id={exercise.id} />
              <span class="plan-title">{exercise.data.title}</span>
              <img class="plan-thumb" src={exercise.data.image} alt={exercise.data.title}
                loading="lazy" decoding="async" width="120" height="90" />
              {exercise.data.description && <span class="plan-desc">{exercise.data.description}</span>}
              {(exercise.data.duration || exercise.data.playerCount) && (
                <span class="plan-tags">
                  {exercise.data.duration && <span class="exercise-tag">⏱ {exercise.data.duration}</span>}
                  {exercise.data.playerCount && <span class="exercise-tag">👥 {exercise.data.playerCount}</span>}
                </span>
              )}
            </label>
          ))}
        </div>
      </section>
    ))}
    <div class="spacer-md"></div>
  </div>

  <script is:inline>
    (function () {
      var STORAGE_KEY = 'kraft:plan:v1';
      var OLD_KEY = 'kraft-plan-selection';
      var checks = document.querySelectorAll('.plan-check');
      var countEl = document.getElementById('planCount');
      var planPrint = document.getElementById('planPrint');

      // Migrate old storage key to versioned key
      try {
        var oldRaw = localStorage.getItem(OLD_KEY);
        if (oldRaw !== null) {
          if (localStorage.getItem(STORAGE_KEY) === null) {
            localStorage.setItem(STORAGE_KEY, oldRaw);
          }
          localStorage.removeItem(OLD_KEY);
        }
      } catch (e) {}

      function syncItem(check) {
        var item = check.closest('.plan-item');
        if (item) item.classList.toggle('selected', check.checked);
      }

      function update() {
        var ids = [];
        for (var i = 0; i < checks.length; i++) {
          if (checks[i].checked) ids.push(checks[i].getAttribute('data-id'));
        }
        // Note: orphaned ids are dropped by design (a warning was shown on load)
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(ids)); } catch (e) {}
        countEl.textContent = ids.length + (ids.length === 1 ? ' Übung ausgewählt' : ' Übungen ausgewählt');
        planPrint.disabled = ids.length === 0;
      }

      function setAll(state) {
        for (var i = 0; i < checks.length; i++) {
          checks[i].checked = state;
          syncItem(checks[i]);
        }
        update();
      }

      // Restore saved selection — tolerate corrupt / non-array data
      var saved = [];
      try {
        var raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
        if (Array.isArray(raw)) saved = raw;
        else if (raw && Array.isArray(raw.ids)) saved = raw.ids; // future format
      } catch (e) {}

      var boxById = {};
      for (var i = 0; i < checks.length; i++) {
        boxById[checks[i].getAttribute('data-id')] = checks[i];
      }

      // Saved ids without a matching checkbox = renamed/deleted CMS entries
      var orphanIds = [];
      for (var i = 0; i < saved.length; i++) {
        var id = saved[i];
        var box = Object.prototype.hasOwnProperty.call(boxById, id) ? boxById[id] : null;
        if (box) {
          box.checked = true;
        } else {
          orphanIds.push(id);
        }
      }

      for (var i = 0; i < checks.length; i++) {
        syncItem(checks[i]);
        checks[i].addEventListener('change', function () {
          syncItem(this);
          update();
        });
      }

      if (orphanIds.length > 0) {
        var msg = document.createElement('div');
        msg.className = 'plan-orphan-warning';
        msg.setAttribute('role', 'alert');
        msg.textContent = orphanIds.length + ' gespeicherte Übung' + (orphanIds.length === 1 ? '' : 'en') +
          ' wurde' + (orphanIds.length === 1 ? '' : 'n') +
          ' nicht mehr gefunden und aus dem Plan entfernt.';
        var controls = document.querySelector('.plan-controls');
        if (controls) controls.after(msg);
      }

      // Writes back storage (without orphans) and sets the print button state
      update();

      // Force selected thumbnails to load before printing (lazy images can print blank)
      function eagerLoadSelectedImages() {
        var imgs = document.querySelectorAll('.plan-item.selected img');
        var pending = [];
        for (var i = 0; i < imgs.length; i++) {
          (function (img) {
            img.loading = 'eager';
            img.fetchPriority = 'high';
            if (img.complete) return;
            pending.push(new Promise(function (resolve) {
              img.addEventListener('load', resolve, { once: true });
              img.addEventListener('error', resolve, { once: true });
              setTimeout(resolve, 3000); // give up after 3s
            }));
          })(imgs[i]);
        }
        return Promise.all(pending);
      }

      window.addEventListener('beforeprint', function () {
        var imgs = document.querySelectorAll('.plan-item.selected img');
        for (var i = 0; i < imgs.length; i++) {
          imgs[i].loading = 'eager';
          imgs[i].fetchPriority = 'high';
        }
      });

      planPrint.addEventListener('click', function () {
        var selected = document.querySelectorAll('.plan-item input:checked');
        if (selected.length === 0) {
          alert('Bitte mindestens eine Übung auswählen.');
          return;
        }
        eagerLoadSelectedImages().then(function () {
          window.print();
        });
      });

      document.getElementById('planSelectAll').addEventListener('click', function () { setAll(true); });
      document.getElementById('planClear').addEventListener('click', function () { setAll(false); });

      // Printing is a no-op in installed iOS PWAs — show a hint instead
      function isInstalledIOSPWA() {
        return window.navigator.standalone === true ||
          (window.matchMedia('(display-mode: standalone)').matches && /iPhone|iPad|iPod/.test(navigator.userAgent));
      }

      if (isInstalledIOSPWA()) {
        var hint = document.createElement('p');
        hint.className = 'plan-print-hint';
        hint.textContent = 'Zum Drucken bitte im Safari-Browser öffnen (nicht in der installierten App).';
        hint.style.cssText = 'color: var(--text-muted); font-size: 13px; margin-top: 8px;';
        planPrint.after(hint);
      }
    })();
  </script>

</Base>

<style>
  .plan-controls {
    position: sticky;
    top: 80px; /* below fixed header */
    z-index: 50;
    background: var(--bg);
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
  }

  .plan-empty {
    padding: 40px 0 80px;
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.7;
  }
  .plan-buttons { display: flex; flex-wrap: wrap; gap: 12px; }

  .plan-btn {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: 12px 20px;
    min-height: 44px;
    cursor: pointer;
    color: var(--text);
    background: none;
    border: 1px solid var(--border);
    transition: color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .plan-btn--primary { color: var(--bg); background-color: var(--accent); border-color: var(--accent); }

  @media (hover: hover) {
    .plan-btn:hover { color: var(--accent); border-color: var(--accent); }
    .plan-btn--primary:hover { color: var(--bg); opacity: 0.85; }
  }

  .plan-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* :global — elements below are created via JS, so Astro's scoping attribute is absent */
  :global(.plan-orphan-warning) {
    background: rgba(255, 70, 75, 0.1);
    border: 1px solid var(--accent-red, #FF464B);
    color: var(--text);
    padding: 12px 16px;
    margin: 12px 0;
    font-size: 14px;
  }

  .plan-count { margin-top: 14px; font-size: 14px; color: var(--text-muted); letter-spacing: 0.5px; }

  .plan-group { margin-bottom: 50px; }

  .plan-group-title {
    font-size: clamp(22px, 3vw, 32px);
    color: var(--accent);
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .plan-list { display: flex; flex-direction: column; gap: 8px; }

  .plan-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 8px 14px;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  @media (hover: hover) {
    .plan-item:hover { border-color: var(--accent); }
  }
  .plan-item.selected { border-color: var(--accent); }

  .plan-check { order: 1; width: 18px; height: 18px; flex-shrink: 0; accent-color: var(--accent); cursor: pointer; }
  .plan-thumb { order: 2; width: 80px; height: 60px; object-fit: contain; background-color: #fff; flex-shrink: 0; }
  .plan-title { order: 3; font-size: 14px; font-weight: 400; letter-spacing: 0.3px; line-height: 1.3; hyphens: auto; overflow-wrap: break-word; }
  .plan-item.selected .plan-title { color: var(--accent); }
  .plan-desc, .plan-tags { display: none; }

  @media print {
    .plan-controls, .plan-group-title, .exercise-header { display: none !important; }
    .plan-group { margin: 0; }
    .plan-list { display: block; }
    .plan-item { display: none; }

    .plan-item.selected {
      display: block;
      page-break-after: always;
      break-after: page;
      border: none;
      background: #fff;
      padding: 0;
      cursor: auto;
    }

    .plan-item.selected .plan-check { display: none; }

    .plan-item.selected .plan-title {
      display: block;
      font-size: 24pt;
      font-weight: 900;
      color: #000;
      margin-bottom: 16pt;
    }

    .plan-item.selected .plan-thumb {
      display: block; width: 100%; height: auto;
      max-height: 16cm; object-fit: contain; background: #fff;
    }

    .plan-item.selected .plan-desc {
      display: block; margin-top: 12pt; font-size: 11pt;
      line-height: 1.6; color: #000; white-space: pre-wrap;
    }

    .plan-item.selected .plan-tags { display: block; margin-top: 8pt; font-size: 10pt; color: #333; }
    .plan-item.selected .exercise-tag { border-color: #ccc; background: none; color: #333; margin-right: 8pt; }

    /* No forced page break after the last printed exercise (avoids trailing blank page) */
    .plan-item.selected:last-of-type,
    .plan-group:last-of-type .plan-item.selected:last-child {
      page-break-after: auto !important;
      break-after: auto !important;
    }

    .spacer-md {
      display: none !important;
    }

    :global(.plan-orphan-warning),
    :global(.plan-print-hint) {
      display: none !important;
    }
  }

  @media (max-width: 700px) {
    .plan-item { gap: 10px; padding: 8px 10px; }
    .plan-thumb { width: 64px; height: 48px; }
    .plan-title { font-size: 13px; }
    .plan-btn { padding: 10px 14px; font-size: 13px; }
  }
</style>
