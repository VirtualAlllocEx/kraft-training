---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const categoryInfo = [
  { slug: 'aufwaermen', name: 'Aufwärmen' },
  { slug: 'passspiel', name: 'Passspiel' },
  { slug: 'torabschluss', name: 'Torabschluss' },
  { slug: 'spielform', name: 'Spielform' },
  { slug: 'halle', name: 'Halle' },
  { slug: 'kondition', name: 'Kondition' },
];

const allExercises = await getCollection('uebungen');

const groups = categoryInfo
  .map(cat => ({
    ...cat,
    exercises: allExercises
      .filter(e => e.data.category === cat.slug)
      .sort((a, b) =>
        ((a.data.order ?? 0) - (b.data.order ?? 0)) ||
        a.data.title.localeCompare(b.data.title, 'de')),
  }))
  .filter(g => g.exercises.length > 0);
---

<Base title="Trainingsplan" description="Trainingsplan für das Fußballtraining zusammenstellen: Übungen aus allen Kategorien auswählen und als druckfertigen Plan ausgeben.">

  <div class="container-lg">
    <div class="exercise-header">
      <h1>Trainingsplan</h1>
      <div class="exercise-meta">
        <span class="exercise-count">Übungen auswählen und ausgewählte Übungen drucken</span>
        <a href="/" class="back-link">&larr; ALLE KATEGORIEN</a>
      </div>
    </div>

    <div class="plan-controls">
      <div class="plan-buttons">
        <button type="button" id="planPrint" class="plan-btn plan-btn--primary">Ausgewählte drucken</button>
        <button type="button" id="planSelectAll" class="plan-btn">Alle auswählen</button>
        <button type="button" id="planClear" class="plan-btn">Auswahl leeren</button>
      </div>
      <p class="plan-count" id="planCount" role="status" aria-live="polite" aria-atomic="true">0 Übungen ausgewählt</p>
    </div>

    <section class="plan-summary" id="planSummary" hidden>
      <h2>Ausgewählte Übungen</h2>
      <p class="plan-summary-meta">
        <span id="planSummaryCount">0 Übungen ausgewählt</span>
        <span id="planSummaryDuration"></span>
      </p>
      <ol id="planSummaryList" class="plan-summary-list"></ol>
      <div class="plan-summary-actions">
        <button type="button" id="planCopyLink" class="plan-btn">🔗 Link kopieren</button>
        <button type="button" id="planShare" class="plan-btn">📤 Teilen</button>
      </div>
    </section>

    {groups.length > 0 && (
      <div class="exercise-search">
        <input
          type="search"
          id="planSearch"
          placeholder="Übung suchen…"
          aria-label="Übung suchen"
          autocomplete="off"
          spellcheck="false"
        />
        <p class="exercise-no-results" id="planNoResults" hidden>Keine Treffer</p>
        <p id="planSearchCount" class="search-count" role="status" aria-live="polite" aria-atomic="true"></p>
      </div>
    )}

    {groups.length === 0 ? (
      <div class="plan-empty">
        <p>Noch keine Übungen vorhanden.</p>
        <p>Sobald Übungen angelegt sind, können sie hier für den Trainingsplan ausgewählt werden.</p>
      </div>
    ) : groups.map(group => (
      <details class="plan-group" open>
        <summary class="plan-group-summary">
          <h2 class="plan-group-title">{group.name}</h2>
          <span class="plan-group-count">{group.exercises.length} {group.exercises.length === 1 ? 'Übung' : 'Übungen'}</span>
        </summary>
        <div class="plan-list">
          {group.exercises.map(exercise => (
            <label class="plan-item"
              data-category={exercise.data.category}
              data-duration={exercise.data.duration ?? ''}
              data-players={exercise.data.playerCount ?? ''}
              data-description={exercise.data.description ?? ''}>
              <input type="checkbox" class="plan-check" value={exercise.id} />
              <span class="plan-title">{exercise.data.title}</span>
              <img class="plan-thumb" src={exercise.data.image} alt={exercise.data.title}
                loading="lazy" decoding="async" width="120" height="90" />
            </label>
          ))}
        </div>
      </details>
    ))}
    <div class="spacer-md"></div>
  </div>

  <script is:inline>
    (function () {
      var STORAGE_KEY = 'kraft:plan:v1';
      var OLD_KEY = 'kraft-plan-selection';
      var checks = document.querySelectorAll('.plan-check');
      var countEl = document.getElementById('planCount');
      var planPrint = document.getElementById('planPrint');
      var summaryEl = document.getElementById('planSummary');
      var summaryList = document.getElementById('planSummaryList');
      var summaryCount = document.getElementById('planSummaryCount');
      var summaryDuration = document.getElementById('planSummaryDuration');
      var copyLinkBtn = document.getElementById('planCopyLink');
      var shareBtn = document.getElementById('planShare');

      // ---- Storage: the plan is a strictly ordered array of exercise ids ----

      function readPlan() {
        try {
          var raw = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
          if (Array.isArray(raw)) return raw;
          if (raw && Array.isArray(raw.ids)) return raw.ids;
          if (raw && Array.isArray(raw.current)) return raw.current; // named-plans format read by the header badge
        } catch (e) {}
        return [];
      }

      function writePlan(ids) {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
        } catch (e) {}
      }

      // Parses "10 Minuten", "15 min", "5-10 min" to minutes (ranges → midpoint)
      function parseDurationMinutes(s) {
        if (!s) return 0;
        var m = s.match(/(\d+)(?:\s*[-–]\s*(\d+))?/);
        if (!m) return 0;
        var lo = parseInt(m[1], 10);
        var hi = m[2] ? parseInt(m[2], 10) : lo;
        return Math.round((lo + hi) / 2);
      }

      function escapeHTML(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
      }

      // Migrate old storage key to versioned key
      try {
        var oldRaw = localStorage.getItem(OLD_KEY);
        if (oldRaw !== null) {
          if (localStorage.getItem(STORAGE_KEY) === null) {
            localStorage.setItem(STORAGE_KEY, oldRaw);
          }
          localStorage.removeItem(OLD_KEY);
        }
      } catch (e) {}

      // id -> checkbox and id -> display data lookups (built once; content is static)
      var boxById = Object.create(null);
      var lookup = Object.create(null);
      for (var i = 0; i < checks.length; i++) {
        var box = checks[i];
        var item = box.closest('.plan-item');
        var img = item ? item.querySelector('img') : null;
        boxById[box.value] = box;
        lookup[box.value] = {
          title: (item && item.querySelector('.plan-title') && item.querySelector('.plan-title').textContent) || box.value,
          duration: (item && item.dataset.duration) || '',
          players: (item && item.dataset.players) || '',
          description: (item && item.dataset.description) || '',
          image: (img && (img.getAttribute('data-src') || img.getAttribute('src'))) || '',
          category: (item && item.dataset.category) || ''
        };
      }

      // Stored ids that exist in this build — guards against stale ids written
      // by another tab so count, summary, share URL and print stay consistent
      function knownIds() {
        var ids = readPlan();
        var out = [];
        for (var k = 0; k < ids.length; k++) {
          if (lookup[ids[k]]) out.push(ids[k]);
        }
        return out;
      }

      // URL-shared plan (?p=id1,id2,...) takes precedence over the stored plan,
      // but never silently: overwriting a non-empty local plan needs confirmation
      function arraysEqual(a, b) {
        if (a.length !== b.length) return false;
        for (var i = 0; i < a.length; i++) if (a[i] !== b[i]) return false;
        return true;
      }

      try {
        var params = new URLSearchParams(window.location.search);
        if (params.has('p')) {
          var urlIds = params.get('p').split(',').filter(Boolean);
          if (urlIds.length > 0) {
            var applyUrlPlan = true;
            var existing = readPlan();
            if (existing.length > 0 && !arraysEqual(existing, urlIds)) {
              applyUrlPlan = confirm(
                'Ein geteilter Trainingsplan mit ' + urlIds.length + ' Übung' + (urlIds.length === 1 ? '' : 'en') +
                ' wurde per Link geöffnet.\n\n' +
                'Dein aktueller Plan (' + existing.length + ' Übung' + (existing.length === 1 ? '' : 'en') +
                ') wird ersetzt. Fortfahren?'
              );
            }
            if (applyUrlPlan) writePlan(urlIds);
          }
          // The param is handled either way (applied or declined) — strip it,
          // otherwise every later reload re-imports the shared plan and, once
          // the user has edited their plan, re-triggers the overwrite confirm.
          history.replaceState({}, '', window.location.pathname);
        }
      } catch (e) {}

      // Restore: check boxes for saved ids, drop orphans (renamed/deleted CMS entries) and dupes
      var savedIds = readPlan();
      var plan = [];
      var orphanIds = [];
      for (var i = 0; i < savedIds.length; i++) {
        var id = savedIds[i];
        if (boxById[id]) {
          if (plan.indexOf(id) === -1) {
            plan.push(id);
            boxById[id].checked = true;
          }
        } else {
          orphanIds.push(id);
        }
      }
      if (plan.length !== savedIds.length) writePlan(plan);

      function syncItem(check) {
        var item = check.closest('.plan-item');
        if (item) item.classList.toggle('selected', check.checked);
      }

      // Checked → append to plan (keeps selection order); unchecked → remove
      function onCheckboxToggle(input) {
        var id = input.value;
        var current = readPlan();
        var idx = current.indexOf(id);
        if (input.checked && idx === -1) {
          current.push(id);
        } else if (!input.checked && idx !== -1) {
          current.splice(idx, 1);
        }
        writePlan(current);
        update();
        renderSummary();
      }

      // Pre-build the hidden print container shortly after each plan change so
      // its images start loading early: Ctrl+P / menu printing has no async
      // hook, and beforeprint cannot wait for image loads.
      var prewarmTimer;
      function schedulePrintPrewarm() {
        clearTimeout(prewarmTimer);
        prewarmTimer = setTimeout(function () { buildPrintContainer(); }, 600);
      }

      function update() {
        var n = knownIds().length;
        countEl.textContent = n + (n === 1 ? ' Übung ausgewählt' : ' Übungen ausgewählt');
        planPrint.disabled = n === 0;
        window.dispatchEvent(new CustomEvent('plan-changed'));
        schedulePrintPrewarm();
      }

      // True while the search filter hides this checkbox's row or group
      function isFilteredOut(check) {
        var item = check.closest('.plan-item');
        if (!item) return false;
        if (item.style.display === 'none') return true;
        var group = item.closest('.plan-group');
        return !!(group && group.style.display === 'none');
      }

      function setAll(state) {
        var ids = state ? readPlan() : [];
        for (var i = 0; i < checks.length; i++) {
          if (state) {
            // With an active search, "Alle auswählen" only selects the matches
            if (isFilteredOut(checks[i])) continue;
            checks[i].checked = true;
            if (ids.indexOf(checks[i].value) === -1) ids.push(checks[i].value);
          } else {
            checks[i].checked = false;
          }
          syncItem(checks[i]);
        }
        writePlan(ids);
        update();
        renderSummary();
      }

      // ---- Summary section: ordered list with reorder controls ----

      function renderSummary() {
        var ids = knownIds();

        if (ids.length === 0) {
          summaryEl.hidden = true;
          summaryList.innerHTML = '';
          return;
        }
        summaryEl.hidden = false;

        summaryCount.textContent = ids.length + ' Übung' + (ids.length === 1 ? '' : 'en') + ' ausgewählt';
        var totalMin = 0;
        for (var j = 0; j < ids.length; j++) {
          var dd = lookup[ids[j]];
          if (dd) totalMin += parseDurationMinutes(dd.duration);
        }
        summaryDuration.textContent = totalMin > 0 ? '  •  Gesamt: ~' + totalMin + ' Min.' : '';

        summaryList.innerHTML = '';
        ids.forEach(function (id, idx) {
          var d = lookup[id];
          if (!d) return;
          var li = document.createElement('li');
          li.className = 'plan-summary-item';
          li.draggable = true;
          li.dataset.id = id;
          li.innerHTML = '<span class="plan-summary-drag" aria-hidden="true">≡</span>' +
            '<img src="' + escapeHTML(d.image) + '" alt="" width="60" height="45" loading="lazy">' +
            '<span class="plan-summary-title">' + escapeHTML(d.title) + '</span>' +
            '<span class="plan-summary-tags">' +
              (d.duration ? '<span>⏱ ' + escapeHTML(d.duration) + '</span>' : '') +
              (d.players ? '<span>👥 ' + escapeHTML(d.players) + '</span>' : '') +
            '</span>' +
            '<div class="plan-summary-controls">' +
              '<button type="button" class="plan-summary-btn" data-action="up" aria-label="Nach oben"' + (idx === 0 ? ' disabled' : '') + '>▲</button>' +
              '<button type="button" class="plan-summary-btn" data-action="down" aria-label="Nach unten"' + (idx === ids.length - 1 ? ' disabled' : '') + '>▼</button>' +
              '<button type="button" class="plan-summary-btn" data-action="remove" aria-label="Entfernen">×</button>' +
            '</div>';
          summaryList.appendChild(li);
        });
      }

      // Up / down / remove buttons
      summaryList.addEventListener('click', function (e) {
        var btn = e.target.closest('.plan-summary-btn');
        if (!btn) return;
        var li = btn.closest('.plan-summary-item');
        var id = li.dataset.id;
        var action = btn.dataset.action;
        var ids = readPlan();
        var idx = ids.indexOf(id);
        if (idx === -1) return;
        if (action === 'up' && idx > 0) {
          var tmp = ids[idx - 1]; ids[idx - 1] = ids[idx]; ids[idx] = tmp;
        } else if (action === 'down' && idx < ids.length - 1) {
          var tmp2 = ids[idx + 1]; ids[idx + 1] = ids[idx]; ids[idx] = tmp2;
        } else if (action === 'remove') {
          ids.splice(idx, 1);
          var cb = boxById[id];
          if (cb) { cb.checked = false; syncItem(cb); }
        }
        writePlan(ids);
        update();
        renderSummary();
      });

      // HTML5 drag-and-drop reordering (mouse; touch users have the arrow buttons)
      var draggedItem = null;

      summaryList.addEventListener('dragstart', function (e) {
        var li = e.target.closest('.plan-summary-item');
        if (!li) return;
        draggedItem = li;
        e.dataTransfer.effectAllowed = 'move';
        // Firefox needs data set for the drag to start
        try { e.dataTransfer.setData('text/plain', li.dataset.id); } catch (err) {}
        li.classList.add('dragging');
      });

      summaryList.addEventListener('dragover', function (e) {
        e.preventDefault();
        if (!draggedItem) return;
        e.dataTransfer.dropEffect = 'move';
        var target = e.target.closest('.plan-summary-item');
        if (!target || target === draggedItem) return;
        var rect = target.getBoundingClientRect();
        var midY = rect.top + rect.height / 2;
        if (e.clientY < midY) {
          target.parentNode.insertBefore(draggedItem, target);
        } else {
          target.parentNode.insertBefore(draggedItem, target.nextSibling);
        }
      });

      summaryList.addEventListener('drop', function (e) {
        e.preventDefault();
      });

      // Fires after drop AND on cancelled drags — persist whatever order the DOM is in
      summaryList.addEventListener('dragend', function () {
        if (!draggedItem) return;
        draggedItem.classList.remove('dragging');
        draggedItem = null;
        persistSummaryOrder();
      });

      function persistSummaryOrder() {
        var items = summaryList.querySelectorAll('.plan-summary-item');
        var newIds = [];
        for (var i = 0; i < items.length; i++) newIds.push(items[i].dataset.id);
        writePlan(newIds);
        update(); // refresh the pre-built print container (its order changed)
        renderSummary(); // re-render to update up/down disabled states
      }

      // Touch reordering via the ≡ handle — HTML5 drag-and-drop is mouse-only.
      // The handle has touch-action: none, so grabbing it never scrolls the page.
      var touchItem = null;
      var touchMoved = false;

      summaryList.addEventListener('touchstart', function (e) {
        var handle = e.target.closest('.plan-summary-drag');
        if (!handle || e.touches.length !== 1) return;
        touchItem = handle.closest('.plan-summary-item');
        touchMoved = false;
        if (touchItem) touchItem.classList.add('dragging');
      }, { passive: true });

      summaryList.addEventListener('touchmove', function (e) {
        if (!touchItem) return;
        e.preventDefault(); // block page scroll while reordering
        var t = e.touches[0];
        var el = document.elementFromPoint(t.clientX, t.clientY);
        var target = el && el.closest ? el.closest('.plan-summary-item') : null;
        if (!target || target === touchItem) return;
        var rect = target.getBoundingClientRect();
        if (t.clientY < rect.top + rect.height / 2) {
          target.parentNode.insertBefore(touchItem, target);
        } else {
          target.parentNode.insertBefore(touchItem, target.nextSibling);
        }
        touchMoved = true;
      }, { passive: false });

      function endTouchDrag() {
        if (!touchItem) return;
        touchItem.classList.remove('dragging');
        touchItem = null;
        if (!touchMoved) return; // plain tap on the handle — order unchanged
        persistSummaryOrder();
      }
      summaryList.addEventListener('touchend', endTouchDrag);
      summaryList.addEventListener('touchcancel', endTouchDrag);

      // ---- Share: encode the ordered plan in the URL ----

      function planUrl() {
        return window.location.origin + '/plan/?p=' + knownIds().join(',');
      }

      var copyResetTimer;
      copyLinkBtn.addEventListener('click', function () {
        var url = planUrl();
        var btn = this;
        function done() {
          btn.textContent = '✓ Link kopiert';
          clearTimeout(copyResetTimer); // rapid double-click: keep one reset timer
          copyResetTimer = setTimeout(function () { btn.textContent = '🔗 Link kopieren'; }, 2000);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(done, function () { window.prompt('Link:', url); });
        } else {
          window.prompt('Link:', url);
        }
      });

      shareBtn.addEventListener('click', function () {
        if (navigator.share) {
          navigator.share({ title: 'Trainingsplan', url: planUrl() }).catch(function () {});
        } else {
          copyLinkBtn.click();
        }
      });

      // ---- Print: render selected exercises in plan order ----

      function buildPrintContainer() {
        var ids = knownIds();
        var container = document.getElementById('planPrintContainer');
        if (!container) {
          container = document.createElement('div');
          container.id = 'planPrintContainer';
          container.className = 'plan-print-container';
          document.querySelector('.container-lg').appendChild(container);
        }
        var sig = ids.join(',');
        if (container.dataset.sig === sig) return container;
        container.dataset.sig = sig;
        container.innerHTML = '';
        ids.forEach(function (id, idx) {
          var d = lookup[id];
          if (!d) return;
          var div = document.createElement('div');
          div.className = 'plan-print-item';
          div.innerHTML = '<div class="plan-print-num">' + (idx + 1) + '.</div>' +
            '<h3>' + escapeHTML(d.title) + '</h3>' +
            '<div class="plan-print-tags">' +
              (d.duration ? '<span>⏱ ' + escapeHTML(d.duration) + '</span>' : '') +
              (d.players ? '<span>👥 ' + escapeHTML(d.players) + '</span>' : '') +
            '</div>' +
            '<img src="' + escapeHTML(d.image) + '" alt="' + escapeHTML(d.title) + '" width="800" height="600">' +
            (d.description ? '<p>' + escapeHTML(d.description) + '</p>' : '');
          container.appendChild(div);
        });
        return container;
      }

      // Wait for print images so they don't print blank
      function waitForImages(container) {
        var imgs = container.querySelectorAll('img');
        var pending = [];
        for (var i = 0; i < imgs.length; i++) {
          (function (img) {
            if (img.complete) return;
            pending.push(new Promise(function (resolve) {
              img.addEventListener('load', resolve, { once: true });
              img.addEventListener('error', resolve, { once: true });
              setTimeout(resolve, 3000); // give up after 3s
            }));
          })(imgs[i]);
        }
        return Promise.all(pending);
      }

      // Covers Ctrl+P / browser menu printing too
      window.addEventListener('beforeprint', function () {
        buildPrintContainer();
      });

      planPrint.addEventListener('click', function () {
        if (knownIds().length === 0) {
          alert('Bitte mindestens eine Übung auswählen.');
          return;
        }
        waitForImages(buildPrintContainer()).then(function () {
          window.print();
        });
      });

      document.getElementById('planSelectAll').addEventListener('click', function () { setAll(true); });
      document.getElementById('planClear').addEventListener('click', function () { setAll(false); });

      for (var i = 0; i < checks.length; i++) {
        syncItem(checks[i]);
        checks[i].addEventListener('change', function () {
          syncItem(this);
          onCheckboxToggle(this);
        });
      }

      if (orphanIds.length > 0) {
        var msg = document.createElement('div');
        msg.className = 'plan-orphan-warning';
        msg.setAttribute('role', 'alert');
        msg.textContent = orphanIds.length + ' gespeicherte Übung' + (orphanIds.length === 1 ? '' : 'en') +
          ' wurde' + (orphanIds.length === 1 ? '' : 'n') +
          ' nicht mehr gefunden und aus dem Plan entfernt.';
        var controls = document.querySelector('.plan-controls');
        if (controls) controls.after(msg);
      }

      update();
      renderSummary();

      // ---- Search: filter the 100+ exercises by title (umlaut-tolerant) ----

      var searchInput = document.getElementById('planSearch');
      if (searchInput) {
        var noResults = document.getElementById('planNoResults');
        var searchCountEl = document.getElementById('planSearchCount');
        var searchGroups = document.querySelectorAll('.plan-group');
        var searchItems = document.querySelectorAll('.plan-item');
        var groupOpenStates = null; // open/closed state before the search started

        // Fold umlauts/diacritics so "ubung" matches "Übung", "strasse" matches "Straße"
        var normalize = function (s) {
          s = (s || '').toLowerCase();
          if (s.normalize) {
            s = s.normalize('NFD').replace(/[̀-ͯ]/g, '');
          }
          return s.replace(/ß/g, 'ss');
        };

        // Precompute normalized titles once
        var normalizedTitles = [];
        for (var t = 0; t < searchItems.length; t++) {
          var titleEl = searchItems[t].querySelector('.plan-title');
          normalizedTitles.push(normalize(titleEl ? titleEl.textContent : ''));
        }

        searchInput.addEventListener('input', function () {
          var query = normalize(searchInput.value.trim());

          // Remember which groups the user had collapsed before searching
          if (query && groupOpenStates === null) {
            groupOpenStates = [];
            for (var g = 0; g < searchGroups.length; g++) groupOpenStates.push(searchGroups[g].open);
          }

          var visible = 0;
          for (var i = 0; i < searchItems.length; i++) {
            var match = query === '' || normalizedTitles[i].indexOf(query) !== -1;
            searchItems[i].style.display = match ? '' : 'none';
            if (match) visible++;
          }

          // Hide groups without matches; open groups that have matches
          for (var g2 = 0; g2 < searchGroups.length; g2++) {
            var group = searchGroups[g2];
            var groupItems = group.querySelectorAll('.plan-item');
            var groupVisible = 0;
            for (var m = 0; m < groupItems.length; m++) {
              if (groupItems[m].style.display !== 'none') groupVisible++;
            }
            group.style.display = (query && groupVisible === 0) ? 'none' : '';
            if (query && groupVisible > 0) group.open = true;
          }

          // Search cleared: restore the collapse states from before the search
          if (query === '' && groupOpenStates !== null) {
            for (var g3 = 0; g3 < searchGroups.length; g3++) searchGroups[g3].open = groupOpenStates[g3];
            groupOpenStates = null;
          }

          if (noResults) noResults.hidden = visible > 0 || query === '';
          if (searchCountEl) {
            searchCountEl.textContent = query
              ? visible + ' von ' + searchItems.length + ' Übungen'
              : '';
          }
        });
      }

      // Printing is a no-op in installed iOS PWAs — show a hint instead
      function isInstalledIOSPWA() {
        return window.navigator.standalone === true ||
