---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const categoryInfo = [
  { slug: 'aufwaermen', name: 'Aufwärmen' },
  { slug: 'passspiel', name: 'Passspiel' },
  { slug: 'torabschluss', name: 'Torabschluss' },
  { slug: 'spielform', name: 'Spielform' },
  { slug: 'halle', name: 'Halle' },
  { slug: 'kondition', name: 'Kondition' },
];

const allExercises = await getCollection('uebungen');

const groups = categoryInfo
  .map(cat => ({
    ...cat,
    exercises: allExercises
      .filter(e => e.data.category === cat.slug)
      .sort((a, b) =>
        ((a.data.order ?? 0) - (b.data.order ?? 0)) ||
        a.data.title.localeCompare(b.data.title, 'de')),
  }))
  .filter(g => g.exercises.length > 0);
---

<Base title="Trainingsplan" description="Übungen auswählen und als Trainingsplan drucken">

  <div class="container-lg">
    <div class="exercise-header">
      <h1>Trainingsplan</h1>
      <div class="exercise-meta">
        <span class="exercise-count">Übungen auswählen und ausgewählte Übungen drucken</span>
        <a href="/" class="back-link">&larr; ALLE KATEGORIEN</a>
      </div>
    </div>

    <div class="plan-controls">
      <div class="plan-buttons">
        <button type="button" id="planPrint" class="plan-btn plan-btn--primary">Ausgewählte drucken</button>
        <button type="button" id="planSelectAll" class="plan-btn">Alle auswählen</button>
        <button type="button" id="planClear" class="plan-btn">Auswahl leeren</button>
      </div>
      <p class="plan-count" id="planCount" aria-live="polite">0 Übungen ausgewählt</p>
    </div>

    {groups.map(group => (
      <section class="plan-group">
        <h2 class="plan-group-title">{group.name}</h2>
        <div class="plan-list">
          {group.exercises.map(exercise => (
            <label class="plan-item">
              <input type="checkbox" class="plan-check" data-id={exercise.id} />
              <span class="plan-title">{exercise.data.title}</span>
              <img class="plan-thumb" src={exercise.data.image} alt={exercise.data.title}
                loading="lazy" decoding="async" width="120" height="90" />
              {exercise.data.description && <span class="plan-desc">{exercise.data.description}</span>}
              {(exercise.data.duration || exercise.data.playerCount) && (
                <span class="plan-tags">
                  {exercise.data.duration && <span class="exercise-tag">⏱ {exercise.data.duration}</span>}
                  {exercise.data.playerCount && <span class="exercise-tag">👥 {exercise.data.playerCount}</span>}
                </span>
              )}
            </label>
          ))}
        </div>
      </section>
    ))}
    <div class="spacer-md"></div>
  </div>

  <script is:inline>
    (function () {
      var KEY = 'kraft-plan-selection';
      var checks = document.querySelectorAll('.plan-check');
      var countEl = document.getElementById('planCount');

      function syncItem(check) {
        var item = check.closest('.plan-item');
        if (item) item.classList.toggle('selected', check.checked);
      }

      function update() {
        var ids = [];
        for (var i = 0; i < checks.length; i++) {
          if (checks[i].checked) ids.push(checks[i].getAttribute('data-id'));
        }
        try { localStorage.setItem(KEY, JSON.stringify(ids)); } catch (e) {}
        countEl.textContent = ids.length + (ids.length === 1 ? ' Übung ausgewählt' : ' Übungen ausgewählt');
      }

      function setAll(state) {
        for (var i = 0; i < checks.length; i++) {
          checks[i].checked = state;
          syncItem(checks[i]);
        }
        update();
      }

      var saved = [];
      try { saved = JSON.parse(localStorage.getItem(KEY)) || []; } catch (e) {}

      for (var i = 0; i < checks.length; i++) {
        if (saved.indexOf(checks[i].getAttribute('data-id')) !== -1) checks[i].checked = true;
        syncItem(checks[i]);
        checks[i].addEventListener('change', function () {
          syncItem(this);
          update();
        });
      }
      update();

      document.getElementById('planPrint').addEventListener('click', function () { window.print(); });
      document.getElementById('planSelectAll').addEventListener('click', function () { setAll(true); });
      document.getElementById('planClear').addEventListener('click', function () { setAll(false); });
    })();
  </script>

</Base>

<style>
  .plan-controls { margin-bottom: 40px; }
  .plan-buttons { display: flex; flex-wrap: wrap; gap: 12px; }

  .plan-btn {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: 12px 20px;
    min-height: 44px;
    cursor: pointer;
    color: var(--text);
    background: none;
    border: 1px solid var(--border);
    transition: color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .plan-btn:hover { color: var(--accent); border-color: var(--accent); }
  .plan-btn--primary { color: var(--bg); background-color: var(--accent); border-color: var(--accent); }
  .plan-btn--primary:hover { color: var(--bg); opacity: 0.85; }

  .plan-count { margin-top: 14px; font-size: 14px; color: var(--text-muted); letter-spacing: 0.5px; }

  .plan-group { margin-bottom: 50px; }

  .plan-group-title {
    font-size: clamp(22px, 3vw, 32px);
    color: var(--accent);
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .plan-list { display: flex; flex-direction: column; gap: 8px; }

  .plan-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 8px 14px;
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .plan-item:hover { border-color: var(--accent); }
  .plan-item.selected { border-color: var(--accent); }

  .plan-check { order: 1; width: 18px; height: 18px; flex-shrink: 0; accent-color: var(--accent); cursor: pointer; }
  .plan-thumb { order: 2; width: 80px; height: 60px; object-fit: contain; background-color: #fff; flex-shrink: 0; }
  .plan-title { order: 3; font-size: 14px; font-weight: 400; letter-spacing: 0.3px; line-height: 1.3; }
  .plan-item.selected .plan-title { color: var(--accent); }
  .plan-desc, .plan-tags { display: none; }

  @media print {
    .plan-controls, .plan-group-title, .exercise-header { display: none !important; }
    .plan-group { margin: 0; }
    .plan-list { display: block; }
    .plan-item { display: none; }

    .plan-item.selected {
      display: block;
      page-break-after: always;
      break-after: page;
      border: none;
      background: #fff;
      padding: 0;
      cursor: auto;
    }

    .plan-item.selected .plan-check { display: none; }

    .plan-item.selected .plan-title {
      display: block;
      font-size: 24pt;
      font-weight: 900;
      color: #000;
      margin-bottom: 16pt;
    }

    .plan-item.selected .plan-thumb {
      display: block; width: 100%; height: auto;
      max-height: 16cm; object-fit: contain; background: #fff;
    }

    .plan-item.selected .plan-desc {
      display: block; margin-top: 12pt; font-size: 11pt;
      line-height: 1.6; color: #000; white-space: pre-wrap;
    }

    .plan-item.selected .plan-tags { display: block; margin-top: 8pt; font-size: 10pt; color: #333; }
    .plan-item.selected .exercise-tag { border-color: #ccc; background: none; color: #333; margin-right: 8pt; }
  }

  @media (max-width: 700px) {
    .plan-item { gap: 10px; padding: 8px 10px; }
    .plan-thumb { width: 64px; height: 48px; }
    .plan-title { font-size: 13px; }
    .plan-btn { padding: 10px 14px; font-size: 13px; }
  }
</style>
