---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Trainingsübungen Bibliothek für Fußballtrainer' } = Astro.props;

const categories = [
  { slug: 'aufwaermen', name: 'Aufwärmen' },
  { slug: 'passspiel', name: 'Passspiel' },
  { slug: 'torabschluss', name: 'Torabschluss' },
  { slug: 'spielform', name: 'Spielform' },
  { slug: 'halle', name: 'Halle' },
  { slug: 'kondition', name: 'Kondition' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#131313" />
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate" />
  <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate" />
  <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="KRAFT.TRAINING" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
  <meta property="og:title" content={`${title} | KRAFT.TRAINING`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_AT" />
  <meta property="og:site_name" content="KRAFT.TRAINING" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
  <meta property="og:image" content={new URL('/og-image.svg', Astro.site).href} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="twitter:image" content={new URL('/og-image.svg', Astro.site).href} />
  <title>{title} | KRAFT.TRAINING</title>
  <script is:inline>{
    (function(){
      // Netlify Identity: invite/recovery/confirmation links from e-mails
      // land on the public site with a token in the URL hash. Load the
      // widget on demand and wire up the right redirect per flow type.
      var h = window.location.hash;
      var flowType = null;
      if (h) {
        if (h.indexOf('invite_token') !== -1) flowType = 'invite';
        else if (h.indexOf('recovery_token') !== -1) flowType = 'recovery';
        else if (h.indexOf('confirmation_token') !== -1) flowType = 'confirmation';
      }

      if (!flowType) return;

      var s = document.createElement('script');
      // Note: no crossOrigin/SRI here — identity.netlify.com is a mutable
      // service endpoint that does not send Access-Control-Allow-Origin,
      // so a CORS-mode (crossorigin) fetch would be blocked by the browser.
      s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
      s.async = true;
      s.onload = function () {
        if (!window.netlifyIdentity) return;
        if (flowType === 'invite' || flowType === 'confirmation') {
          // Login means the password was set (invite) or the e-mail was
          // confirmed — safe to go straight to the CMS.
          window.netlifyIdentity.on('login', function () {
            document.location.href = '/admin/';
          });
        } else if (flowType === 'recovery') {
          // For recovery, 'login' fires as soon as the token verifies —
          // BEFORE the user has saved a new password. Redirecting on login
          // would skip the reset form entirely. Instead wait until the
          // widget closes (user finished or cancelled the reset), then
          // redirect only if a session exists.
          window.netlifyIdentity.on('close', function () {
            if (window.netlifyIdentity.currentUser()) {
              document.location.href = '/admin/';
            }
          });
        }
        // Open the widget (it processes the hash token automatically)
        if (window.netlifyIdentity.open) {
          window.netlifyIdentity.open();
        }
      };
      s.onerror = function () {
        // Widget failed to load (ad blocker, network) — show a hint
        var msg = document.createElement('div');
        msg.style.cssText = 'position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#FF464B;color:#fff;padding:16px 24px;font-weight:700;z-index:10001;max-width:90vw;text-align:center;';
        msg.innerHTML = 'Login-System konnte nicht geladen werden.<br>Bitte Ad-Blocker pr&uuml;fen oder direkt zu /admin/ gehen.';
        (document.body || document.documentElement).appendChild(msg);
      };
      document.head.appendChild(s);
    })();
  }</script>
</head>
<body>

  <noscript>
    <div style="background:#D4FE00;color:#131313;text-align:center;padding:12px;font-weight:700;font-family:Inter,sans-serif;">
      JavaScript wird benötigt, um diese Seite zu verwenden.
    </div>
  </noscript>

  <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
  <span id="circle"></span>

  <!-- Fixed header -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="site-logo"><span>KRAFT.</span>TRAINING</a>
      <div class="header-actions">
        <button type="button" class="logout-btn" id="logoutBtn" hidden aria-label="Abmelden">Abmelden</button>
        <a href="/plan/" class="plan-badge" id="planBadge" hidden aria-label="Trainingsplan">
          <span class="plan-badge-icon" aria-hidden="true">📋</span>
          <span class="plan-badge-count" id="planBadgeCount">0</span>
        </a>
        <button class="burger" id="burgerBtn" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navOverlay" type="button">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Full-screen navigation overlay -->
  <nav class="nav-overlay" id="navOverlay" aria-hidden="true" inert>
    <ul class="nav-links">
      <li>
        <a href="/" class={currentPath === '/' ? 'active' : ''}>STARTSEITE</a>
      </li>
      {categories.map(cat => (
        <li>
          <a
            href={`/kategorie/${cat.slug}/`}
            class={currentPath.startsWith(`/kategorie/${cat.slug}`) ? 'active' : ''}
          >
            {cat.name.toUpperCase()}
          </a>
        </li>
      ))}
      <li>
        <a href="/plan/" class={currentPath.startsWith('/plan') ? 'active' : ''}>TRAININGSPLAN</a>
      </li>
      <li>
        <a href="/hilfe/" class={currentPath.startsWith('/hilfe') ? 'active' : ''}>HILFE</a>
      </li>
    </ul>
    <div class="nav-bottom">
      <a href="/admin/" target="_blank" rel="noopener noreferrer">ADMIN</a>
    </div>
  </nav>

  <!-- Page content -->
  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <!-- Scroll to top button -->
  <button class="scroll-top" id="scrollTop" aria-label="Nach oben scrollen" type="button">↑</button>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo"><span>KRAFT.</span>TRAINING</a>
      <p class="footer-text">TRAININGSÜBUNGEN BIBLIOTHEK</p>
      <div class="footer-links">
        <a href="/plan/">Trainingsplan</a>
        <a href="/hilfe/">Hilfe</a>
        <a href="/admin/" target="_blank" rel="noopener noreferrer">Admin</a>
        <a href="https://kraftader.at" target="_blank" rel="noopener noreferrer">kraftader.at</a>
      </div>
    </div>
  </footer>

  <!-- Lightbox overlay -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Bildansicht" aria-hidden="true" inert>
    <button class="lightbox-close" id="lightboxClose" aria-label="Schließen">&times;</button>
    <button class="lightbox-prev" id="lightboxPrev" aria-label="Vorheriges Bild">&#8249;</button>
    <div class="lightbox-stage">
      <img id="lightboxImg" src="" alt="" />
      <div class="lightbox-meta" id="lightboxMeta">
        <div class="lightbox-title" id="lightboxTitle" aria-live="polite" role="status"></div>
        <div class="lightbox-tags" id="lightboxTags" hidden></div>
        <p class="lightbox-description" id="lightboxDescription" hidden></p>
        <div class="lightbox-actions" id="lightboxActions" hidden>
          <a class="lightbox-video" id="lightboxVideo" href="#" target="_blank" rel="noopener noreferrer" hidden>▶ Video ansehen</a>
          <button type="button" class="lightbox-plan-btn" id="lightboxPlanBtn" hidden>+ Zum Plan</button>
          <a class="lightbox-details" id="lightboxDetails" href="#" hidden>Details ansehen</a>
        </div>
      </div>
    </div>
    <button class="lightbox-next" id="lightboxNext" aria-label="Nächstes Bild">&#8250;</button>
  </div>

  <script is:inline>
    (function () {
      var burger = document.getElementById('burgerBtn');
      var nav = document.getElementById('navOverlay');
      var mainContent = document.getElementById('main-content');
      var siteHeader = document.getElementById('siteHeader');
      var scrollTopBtn = document.getElementById('scrollTop');
      var footer = document.querySelector('.site-footer');

      function closeMenu() {
        burger.classList.remove('open');
        nav.classList.remove('open');
        document.body.style.overflow = '';
        burger.setAttribute('aria-label', 'Menü öffnen');
        burger.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
        nav.setAttribute('inert', '');
      }

      burger.addEventListener('click', function () {
        var isOpen = burger.classList.toggle('open');
        nav.classList.toggle('open');
        document.body.style.overflow = isOpen ? 'hidden' : '';
        burger.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
        burger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        nav.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        if (isOpen) {
          nav.removeAttribute('inert');
          var firstLink = nav.querySelector('a');
          if (firstLink) firstLink.focus();
        } else {
          nav.setAttribute('inert', '');
          burger.focus();
        }
      });

      var navLinks = document.querySelectorAll('.nav-links a, .nav-bottom a');
      for (var i = 0; i < navLinks.length; i++) {
        navLinks[i].addEventListener('click', closeMenu);
      }

      var scrollTicking = false;

      window.addEventListener('scroll', function () {
        if (!scrollTicking) {
          requestAnimationFrame(function () {
            var y = window.scrollY;
            if (y > 80) {
              siteHeader.classList.add('scrolled');
            } else {
              siteHeader.classList.remove('scrolled');
            }
            if (y > 400) {
              scrollTopBtn.classList.add('visible');
            } else {
              scrollTopBtn.classList.remove('visible');
            }
            scrollTicking = false;
          });
          scrollTicking = true;
        }
      }, { passive: true });

      scrollTopBtn.addEventListener('click', function () {
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
      });

      // --- Custom cursor (fine-pointer devices only, event delegation) ---
      var circle = document.getElementById('circle');
      var supportsFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      if (window.innerWidth > 1100 && supportsFinePointer && circle) {
        var mx = -100, my = -100;
        var rafId = 0;

        function updateCursor() {
          circle.style.transform = 'translate(calc(' + mx + 'px - 50%), calc(' + my + 'px - 50%))';
          rafId = 0;
        }

        document.addEventListener('mousemove', function (e) {
          mx = e.clientX;
          my = e.clientY;
          if (!rafId) {
            rafId = requestAnimationFrame(updateCursor);
          }
        }, { passive: true });

        document.addEventListener('mouseover', function (e) {
          if (e.target.closest('a, button, .exercise-card')) {
            circle.classList.add('hover');
          } else {
            circle.classList.remove('hover');
          }
        }, { passive: true });
      } else if (circle) {
        circle.style.display = 'none';
      }

      // --- Lightbox with prev/next + touch swipe + focus trap ---
      var lightbox = document.getElementById('lightbox');
      var lightboxImg = document.getElementById('lightboxImg');
      var lightboxTitle = document.getElementById('lightboxTitle');
      var lightboxClose = document.getElementById('lightboxClose');
      var lightboxPrev = document.getElementById('lightboxPrev');
      var lightboxNext = document.getElementById('lightboxNext');
      var lightboxMeta = document.getElementById('lightboxMeta');
      var lightboxActions = document.getElementById('lightboxActions');
      var lightboxTags = document.getElementById('lightboxTags');
      var lightboxDescription = document.getElementById('lightboxDescription');
      var lightboxVideo = document.getElementById('lightboxVideo');
      var lightboxDetails = document.getElementById('lightboxDetails');
      var lightboxPlanBtn = document.getElementById('lightboxPlanBtn');

      // --- Trainingsplan storage helpers (shared key with /plan/) ---
      var PLAN_STORAGE_KEY = 'kraft:plan:v1';

      function readPlan() {
        try {
          var raw = JSON.parse(localStorage.getItem(PLAN_STORAGE_KEY) || 'null');
          if (Array.isArray(raw)) return raw;
          if (raw && Array.isArray(raw.ids)) return raw.ids; // future format
          if (raw && Array.isArray(raw.current)) return raw.current; // T5 named-plans format
        } catch (e) {}
        return [];
      }

      function writePlan(ids) {
        try {
          var raw = JSON.parse(localStorage.getItem(PLAN_STORAGE_KEY) || 'null');
          if (raw && typeof raw === 'object' && !Array.isArray(raw)) {
            raw.current = ids;
            localStorage.setItem(PLAN_STORAGE_KEY, JSON.stringify(raw));
          } else {
            localStorage.setItem(PLAN_STORAGE_KEY, JSON.stringify(ids));
          }
        } catch (e) {}
      }

      function updatePlanBadge() {
        var badge = document.getElementById('planBadge');
        var count = document.getElementById('planBadgeCount');
        if (!badge || !count) return;
        var ids = readPlan();
        if (ids.length > 0) {
          badge.hidden = false;
          count.textContent = String(ids.length);
          badge.setAttribute('aria-label', 'Trainingsplan, ' + ids.length + (ids.length === 1 ? ' Übung' : ' Übungen'));
        } else {
          badge.hidden = true;
        }
      }

      window.updatePlanBadge = updatePlanBadge;
      window.addEventListener('plan-changed', updatePlanBadge);
      updatePlanBadge();

      function isSafeUrl(url) {
        if (!url) return false;
        try {
          var u = new URL(url);
          return u.protocol === 'http:' || u.protocol === 'https:';
        } catch (e) {
          return false;
        }
      }

      function updateLightboxPlanBtn(entry) {
        if (!lightboxPlanBtn) return;
        var hasId = !!(entry && entry.id);
        if (!hasId) {
          lightboxPlanBtn.hidden = true;
          return;
        }
        var inPlan = readPlan().indexOf(entry.id) !== -1;
        lightboxPlanBtn.hidden = false;
        lightboxPlanBtn.classList.toggle('in-plan', inPlan);
        lightboxPlanBtn.textContent = inPlan ? '✓ Im Plan' : '+ Zum Plan';
        lightboxPlanBtn.setAttribute('aria-pressed', inPlan ? 'true' : 'false');
        lightboxPlanBtn.setAttribute('aria-label',
          entry.title + (inPlan ? ' aus dem Trainingsplan entfernen' : ' zum Trainingsplan hinzufügen'));
      }

      function updateLbMeta(entry) {
        if (!lightboxMeta) return;
        var hasDesc = !!(entry && entry.description);
        var hasVideo = !!(entry && entry.video) && isSafeUrl(entry.video);
        var hasDuration = !!(entry && entry.duration);
        var hasPlayers = !!(entry && entry.players);
        var hasId = !!(entry && entry.id);

        if (lightboxTags) {
          lightboxTags.innerHTML = '';
          lightboxTags.hidden = !(hasDuration || hasPlayers);
          if (hasDuration) {
            var t1 = document.createElement('span');
            t1.className = 'lightbox-tag';
            t1.textContent = '⏱ ' + entry.duration;
            lightboxTags.appendChild(t1);
          }
          if (hasPlayers) {
            var t2 = document.createElement('span');
            t2.className = 'lightbox-tag';
            t2.textContent = '👥 ' + entry.players;
            lightboxTags.appendChild(t2);
          }
        }
        if (lightboxDescription) {
          lightboxDescription.textContent = hasDesc ? entry.description : '';
          lightboxDescription.hidden = !hasDesc;
        }
        if (lightboxVideo) {
          if (hasVideo) {
            lightboxVideo.href = entry.video;
            lightboxVideo.hidden = false;
          } else {
            lightboxVideo.hidden = true;
            lightboxVideo.removeAttribute('href');
          }
        }
        if (lightboxDetails) {
          if (hasId) {
            lightboxDetails.href = '/uebung/' + encodeURIComponent(entry.id) + '/';
            lightboxDetails.hidden = false;
          } else {
            lightboxDetails.hidden = true;
            lightboxDetails.removeAttribute('href');
          }
        }
        updateLightboxPlanBtn(entry);
        // Meta panel is always visible (the title lives inside it); only the
        // actions row collapses when none of its buttons are shown.
        if (lightboxActions) {
          lightboxActions.hidden = !(
            (lightboxVideo && !lightboxVideo.hidden) ||
            (lightboxPlanBtn && !lightboxPlanBtn.hidden) ||
            (lightboxDetails && !lightboxDetails.hidden)
          );
        }
      }

      var lbImages = [];
      var lbIndex = -1;
      var lastFocusedEl = null;
      var lightboxCleanupTimer = null;

      function setBackgroundInert(inert) {
        var els = [mainContent, siteHeader, scrollTopBtn, footer];
        for (var i = 0; i < els.length; i++) {
          if (!els[i]) continue;
          if (inert) {
            els[i].setAttribute('inert', '');
            els[i].setAttribute('aria-hidden', 'true');
          } else {
            els[i].removeAttribute('inert');
            els[i].removeAttribute('aria-hidden');
          }
        }
      }

      function closeLightbox() {
        lightbox.classList.remove('open');
        lightbox.setAttribute('inert', '');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        setBackgroundInert(false);
        if (lastFocusedEl && typeof lastFocusedEl.focus === 'function') {
          lastFocusedEl.focus();
        }
        lastFocusedEl = null;
        if (lightboxCleanupTimer) clearTimeout(lightboxCleanupTimer);
        lightboxCleanupTimer = setTimeout(function () {
          if (!lightbox.classList.contains('open')) {
            lightboxImg.src = '';
          }
          lightboxCleanupTimer = null;
        }, 350);
      }

      function showLbImage(idx) {
        if (idx < 0 || idx >= lbImages.length) return;
        if (lightboxCleanupTimer) { clearTimeout(lightboxCleanupTimer); lightboxCleanupTimer = null; }
        if (!lastFocusedEl) lastFocusedEl = document.activeElement;
        lbIndex = idx;
        window.lbIndex = idx;
        lightboxImg.src = lbImages[idx].src;
        lightboxImg.alt = lbImages[idx].title;
        lightboxTitle.textContent = (idx + 1) + ' von ' + lbImages.length + ' – ' + lbImages[idx].title;
        updateLbMeta(lbImages[idx]);
        if (!lightbox.classList.contains('open')) {
          lightbox.classList.add('open');
          lightbox.removeAttribute('inert');
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          setBackgroundInert(true);
          // Only move focus on first open — not on every prev/next change
          lightboxClose.focus();
        }
        updateLbArrows();
      }

      function updateLbArrows() {
        if (lbImages.length <= 1) {
          lightboxPrev.style.display = 'none';
          lightboxNext.style.display = 'none';
        } else {
          lightboxPrev.style.display = lbIndex > 0 ? 'flex' : 'none';
          lightboxNext.style.display = lbIndex < lbImages.length - 1 ? 'flex' : 'none';
        }
      }

      lightboxPrev.addEventListener('click', function (e) {
        e.stopPropagation();
        if (lbIndex > 0) showLbImage(lbIndex - 1);
      });

      lightboxNext.addEventListener('click', function (e) {
        e.stopPropagation();
        if (lbIndex < lbImages.length - 1) showLbImage(lbIndex + 1);
      });

      lightboxClose.addEventListener('click', function (e) {
        e.stopPropagation();
        closeLightbox();
      });

      if (lightboxPlanBtn) {
        lightboxPlanBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          var entry = lbImages[lbIndex];
          if (!entry || !entry.id) return;
          var ids = readPlan();
          var idx = ids.indexOf(entry.id);
          if (idx === -1) {
            ids.push(entry.id);
          } else {
            ids.splice(idx, 1);
          }
          writePlan(ids);
          updateLightboxPlanBtn(entry);
          window.dispatchEvent(new CustomEvent('plan-changed'));
        });
      }

      lightbox.addEventListener('click', function (e) {
        if (e.target === lightbox) closeLightbox();
      });

      // Focus trap inside lightbox
      lightbox.addEventListener('keydown', function (e) {
        if (!lightbox.classList.contains('open')) return;
        if (e.key !== 'Tab') return;
        var focusables = lightbox.querySelectorAll('button:not([hidden]), a[href]:not([hidden])');
        var visible = [];
        for (var b = 0; b < focusables.length; b++) {
          var el = focusables[b];
          // Skip elements hidden via CSS display:none or their parent hidden attr
          if (el.hidden) continue;
          var style = window.getComputedStyle(el);
          if (style.display === 'none' || style.visibility === 'hidden') continue;
          visible.push(el);
        }
        if (visible.length === 0) return;
        var first = visible[0];
        var last = visible[visible.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      });

      // Touch swipe support for lightbox
      var touchStartX = 0;
      var touchStartY = 0;
      var touchId = null;

      lightbox.addEventListener('touchstart', function (e) {
        if (e.touches.length === 1) {
          touchId = e.touches[0].identifier;
          touchStartX = e.touches[0].screenX;
          touchStartY = e.touches[0].screenY;
        }
      }, { passive: true });

      lightbox.addEventListener('touchmove', function (e) {
        // Never preventDefault multi-touch (pinch-zoom must work)
        if (e.touches.length !== 1) return;
        if (touchId !== null && lightbox.classList.contains('open')) {
          var touch = null;
          for (var t = 0; t < e.touches.length; t++) {
            if (e.touches[t].identifier === touchId) { touch = e.touches[t]; break; }
          }
          if (touch) {
            var dx = Math.abs(touch.screenX - touchStartX);
            var dy = Math.abs(touch.screenY - touchStartY);
            // Only prevent when clearly horizontal AND we're on the image itself
            if (dx > dy && dx > 15) e.preventDefault();
          }
        }
      }, { passive: false });

      lightbox.addEventListener('touchend', function (e) {
        var touch = null;
        for (var t = 0; t < e.changedTouches.length; t++) {
          if (e.changedTouches[t].identifier === touchId) {
            touch = e.changedTouches[t];
            break;
          }
        }
        if (!touch) return;
        touchId = null;
        var dx = touch.screenX - touchStartX;
        var dy = touch.screenY - touchStartY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
          if (dx < 0 && lbIndex < lbImages.length - 1) {
            showLbImage(lbIndex + 1);
          } else if (dx > 0 && lbIndex > 0) {
            showLbImage(lbIndex - 1);
          }
        }
      }, { passive: true });

      lightbox.addEventListener('touchcancel', function () {
        touchId = null;
      }, { passive: true });

      document.addEventListener('keydown', function (e) {
        if (lightbox.classList.contains('open')) {
          if (e.key === 'Escape') { closeLightbox(); return; }
          if (e.key === 'ArrowRight' && lbIndex < lbImages.length - 1) { showLbImage(lbIndex + 1); return; }
          if (e.key === 'ArrowLeft' && lbIndex > 0) { showLbImage(lbIndex - 1); return; }
        } else if (e.key === 'Escape' && nav.classList.contains('open')) {
          closeMenu();
          burger.focus();
        }
      });

      // Expose globally for [slug].astro
      window.showLbImage = showLbImage;
      window.setLbImages = function (images) { lbImages = images; window.lbImages = images; };
      window.setLbIndex = function (idx) { lbIndex = idx; window.lbIndex = idx; };

      // CRITICAL FIX: pick up images stashed by [slug].astro if it ran first
      if (window._pendingLbImages) {
        lbImages = window._pendingLbImages;
        window.lbImages = lbImages;
        delete window._pendingLbImages;
      }

      // Note: the invite/recovery/confirmation token handling lives in the
      // <head> inline script (script.onload wiring) — no polling needed here.

      // --- Logout button: only visible when a Netlify Identity session exists ---
      var hasSession = false;
      try {
        var rawUser = localStorage.getItem('gotrue.user');
        if (rawUser) {
          var parsedUser = JSON.parse(rawUser);
          if (parsedUser && parsedUser.token && parsedUser.email) hasSession = true;
        }
      } catch (e) {}

      var logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn && hasSession) {
        logoutBtn.hidden = false;
        logoutBtn.addEventListener('click', function () {
          if (!confirm('Wirklich abmelden?')) return;
          var reloaded = false;
          function reloadOnce() {
            if (reloaded) return;
            reloaded = true;
            window.location.reload();
          }
          if (window.netlifyIdentity && window.netlifyIdentity.logout) {
            // Widget is loaded (identity flow) — use the proper logout and
            // reload when it actually finishes (a fixed short timer could
            // reload before the session was cleared on slow networks).
            window.netlifyIdentity.on('logout', reloadOnce);
            window.netlifyIdentity.logout();
            // Fallback: if the logout event never fires (network error),
            // clear the local session ourselves and reload anyway.
            setTimeout(function () {
              try { localStorage.removeItem('gotrue.user'); } catch (e) {}
              reloadOnce();
            }, 2000);
          } else {
            // No widget on the public site — just clear the stored token
            try { localStorage.removeItem('gotrue.user'); } catch (e) {}
            window.location.reload();
          }
        });
      }
    })();
  </script>

  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        try {
          navigator.serviceWorker.register('/sw.js').then(function (reg) {
            reg.addEventListener('updatefound', function () {
              var newWorker = reg.installing;
              if (!newWorker) return;
              newWorker.addEventListener('statechange', function () {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  /* A new version is ready: show a toast with a reload button.
                     Guard against stacking: updatefound can fire again for a
                     later deploy while the tab stays open. */
                  if (document.getElementById('swUpdateToast')) return;
                  var toast = document.createElement('div');
                  toast.id = 'swUpdateToast';
                  toast.style.cssText = 'position:fixed;bottom:20px;bottom:calc(20px + env(safe-area-inset-bottom, 0px));left:50%;transform:translateX(-50%);background:#D4FE00;color:#131313;padding:12px 20px;border-radius:0;font-weight:700;z-index:10001;box-shadow:0 4px 20px rgba(0,0,0,0.3);max-width:calc(100vw - 24px);text-align:center;';
                  toast.innerHTML = 'Neue Version verfügbar &nbsp;<button style="background:#131313;color:#D4FE00;border:none;padding:6px 12px;margin-left:8px;font-weight:700;cursor:pointer;">Aktualisieren</button>';
                  toast.querySelector('button').addEventListener('click', function () {
                    window.location.reload();
                  });
                  document.body.appendChild(toast);
                }
              });
            });
          }).catch(function () {});
        } catch (e) {
          /* Service worker registration must never break the page */
        }
      });
    }
  </script>

</body>
</html>
