---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Trainingsübungen Bibliothek für Fußballtrainer' } = Astro.props;

const categories = [
  { slug: 'aufwaermen', name: 'Aufwärmen' },
  { slug: 'passspiel', name: 'Passspiel' },
  { slug: 'torabschluss', name: 'Torabschluss' },
  { slug: 'spielform', name: 'Spielform' },
  { slug: 'halle', name: 'Halle' },
  { slug: 'kondition', name: 'Kondition' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#131313" />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta property="og:title" content={`${title} | KRAFT.TRAINING`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="de_AT" />
  <meta property="og:site_name" content="KRAFT.TRAINING" />
  <meta name="twitter:card" content="summary" />
  <title>{title} | KRAFT.TRAINING</title>
  <script is:inline>{
    (function(){
      var h = window.location.hash;
      if (h && (h.indexOf('invite_token') !== -1 || h.indexOf('recovery_token') !== -1 || h.indexOf('confirmation_token') !== -1)) {
        var s = document.createElement('script');
        s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
        document.head.appendChild(s);
      }
    })();
  }</script>
</head>
<body>

  <noscript>
    <div style="background:#D4FE00;color:#131313;text-align:center;padding:12px;font-weight:700;font-family:Inter,sans-serif;">
      JavaScript wird benötigt, um diese Seite zu verwenden.
    </div>
  </noscript>

  <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
  <span id="circle"></span>

  <!-- Fixed header -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="site-logo"><span>KRAFT.</span>TRAINING</a>
      <button class="burger" id="burgerBtn" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navOverlay" type="button">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Full-screen navigation overlay -->
  <nav class="nav-overlay" id="navOverlay" aria-hidden="true" inert>
    <ul class="nav-links">
      <li>
        <a href="/" class={currentPath === '/' ? 'active' : ''}>STARTSEITE</a>
      </li>
      {categories.map(cat => (
        <li>
          <a
            href={`/kategorie/${cat.slug}/`}
            class={currentPath.includes(cat.slug) ? 'active' : ''}
          >
            {cat.name.toUpperCase()}
          </a>
        </li>
      ))}
    </ul>
    <div class="nav-bottom">
      <a href="/admin/" target="_blank" rel="noopener">ADMIN</a>
    </div>
  </nav>

  <!-- Page content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Scroll to top button -->
  <button class="scroll-top" id="scrollTop" aria-label="Nach oben scrollen" type="button">↑</button>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo"><span>KRAFT.</span>TRAINING</a>
      <p class="footer-text">TRAININGSÜBUNGEN BIBLIOTHEK</p>
      <div class="footer-links">
        <a href="/admin/" target="_blank" rel="noopener">Admin</a>
        <a href="https://kraftader.at" target="_blank" rel="noopener">kraftader.at</a>
      </div>
    </div>
  </footer>

  <!-- Lightbox overlay -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Bild vergrößern" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="Schließen">&times;</button>
    <button class="lightbox-prev" id="lightboxPrev" aria-label="Vorheriges Bild">&#8249;</button>
    <div class="lightbox-stage">
      <img id="lightboxImg" src="" alt="" />
      <div class="lightbox-meta" id="lightboxMeta" hidden>
        <div class="lightbox-tags" id="lightboxTags"></div>
        <p class="lightbox-description" id="lightboxDescription"></p>
        <a class="lightbox-video" id="lightboxVideo" href="#" target="_blank" rel="noopener" hidden>▶ Video ansehen</a>
      </div>
    </div>
    <button class="lightbox-next" id="lightboxNext" aria-label="Nächstes Bild">&#8250;</button>
    <div class="lightbox-title" id="lightboxTitle" aria-live="polite" role="status"></div>
  </div>

  <script is:inline>
    (function () {
      var burger = document.getElementById('burgerBtn');
      var nav = document.getElementById('navOverlay');
      var mainContent = document.getElementById('main-content');
      var siteHeader = document.getElementById('siteHeader');
      var scrollTopBtn = document.getElementById('scrollTop');
      var footer = document.querySelector('.site-footer');

      function closeMenu() {
        burger.classList.remove('open');
        nav.classList.remove('open');
        document.body.style.overflow = '';
        burger.setAttribute('aria-label', 'Menü öffnen');
        burger.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
        nav.setAttribute('inert', '');
      }

      burger.addEventListener('click', function () {
        var isOpen = burger.classList.toggle('open');
        nav.classList.toggle('open');
        document.body.style.overflow = isOpen ? 'hidden' : '';
        burger.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
        burger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        nav.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        if (isOpen) {
          nav.removeAttribute('inert');
          var firstLink = nav.querySelector('a');
          if (firstLink) firstLink.focus();
        } else {
          nav.setAttribute('inert', '');
          burger.focus();
        }
      });

      var navLinks = document.querySelectorAll('.nav-links a, .nav-bottom a');
      for (var i = 0; i < navLinks.length; i++) {
        navLinks[i].addEventListener('click', closeMenu);
      }

      var scrollTicking = false;

      window.addEventListener('scroll', function () {
        if (!scrollTicking) {
          requestAnimationFrame(function () {
            var y = window.scrollY;
            if (y > 80) {
              siteHeader.classList.add('scrolled');
            } else {
              siteHeader.classList.remove('scrolled');
            }
            if (y > 400) {
              scrollTopBtn.classList.add('visible');
            } else {
              scrollTopBtn.classList.remove('visible');
            }
            scrollTicking = false;
          });
          scrollTicking = true;
        }
      }, { passive: true });

      scrollTopBtn.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // --- Custom cursor (desktop only, event delegation) ---
      var circle = document.getElementById('circle');
      if (window.innerWidth > 1100 && circle) {
        var mx = -100, my = -100;
        var rafId = 0;

        function updateCursor() {
          circle.style.transform = 'translate(calc(' + mx + 'px - 50%), calc(' + my + 'px - 50%))';
          rafId = 0;
        }

        document.addEventListener('mousemove', function (e) {
          mx = e.clientX;
          my = e.clientY;
          if (!rafId) {
            rafId = requestAnimationFrame(updateCursor);
          }
        }, { passive: true });

        document.addEventListener('mouseover', function (e) {
          if (e.target.closest('a, button, .exercise-card')) {
            circle.classList.add('hover');
          } else {
            circle.classList.remove('hover');
          }
        }, { passive: true });
      } else if (circle) {
        circle.style.display = 'none';
      }

      // --- Lightbox with prev/next + touch swipe + focus trap ---
      var lightbox = document.getElementById('lightbox');
      var lightboxImg = document.getElementById('lightboxImg');
      var lightboxTitle = document.getElementById('lightboxTitle');
      var lightboxClose = document.getElementById('lightboxClose');
      var lightboxPrev = document.getElementById('lightboxPrev');
      var lightboxNext = document.getElementById('lightboxNext');
      var lightboxMeta = document.getElementById('lightboxMeta');
      var lightboxTags = document.getElementById('lightboxTags');
      var lightboxDescription = document.getElementById('lightboxDescription');
      var lightboxVideo = document.getElementById('lightboxVideo');

      function updateLbMeta(entry) {
        if (!lightboxMeta) return;
        var hasDesc = !!(entry && entry.description);
        var hasVideo = !!(entry && entry.video);
        var hasDuration = !!(entry && entry.duration);
        var hasPlayers = !!(entry && entry.players);
        var anything = hasDesc || hasVideo || hasDuration || hasPlayers;

        if (lightboxTags) {
          lightboxTags.innerHTML = '';
          if (hasDuration) {
            var t1 = document.createElement('span');
            t1.className = 'lightbox-tag';
            t1.textContent = '⏱ ' + entry.duration;
            lightboxTags.appendChild(t1);
          }
          if (hasPlayers) {
            var t2 = document.createElement('span');
            t2.className = 'lightbox-tag';
            t2.textContent = '👥 ' + entry.players;
            lightboxTags.appendChild(t2);
          }
        }
        if (lightboxDescription) {
          lightboxDescription.textContent = hasDesc ? entry.description : '';
          lightboxDescription.hidden = !hasDesc;
        }
        if (lightboxVideo) {
          if (hasVideo) {
            lightboxVideo.href = entry.video;
            lightboxVideo.hidden = false;
          } else {
            lightboxVideo.hidden = true;
            lightboxVideo.removeAttribute('href');
          }
        }
        lightboxMeta.hidden = !anything;
      }

      var lbImages = [];
      var lbIndex = -1;
      var lastFocusedEl = null;

      function setBackgroundInert(inert) {
        var els = [mainContent, siteHeader, scrollTopBtn, footer];
        for (var i = 0; i < els.length; i++) {
          if (!els[i]) continue;
          if (inert) {
            els[i].setAttribute('inert', '');
            els[i].setAttribute('aria-hidden', 'true');
          } else {
            els[i].removeAttribute('inert');
            els[i].removeAttribute('aria-hidden');
          }
        }
      }

      function openLightbox(src, title) {
        lastFocusedEl = document.activeElement;
        lightboxImg.src = src;
        lightboxImg.alt = title || '';
        lightboxTitle.textContent = title || '';
        updateLbMeta(null);
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        setBackgroundInert(true);
        updateLbArrows();
        lightboxClose.focus();
      }

      function closeLightbox() {
        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        setBackgroundInert(false);
        if (lastFocusedEl && typeof lastFocusedEl.focus === 'function') {
          lastFocusedEl.focus();
        }
        lastFocusedEl = null;
        setTimeout(function () {
          if (!lightbox.classList.contains('open')) {
            lightboxImg.src = '';
          }
        }, 350);
      }

      function showLbImage(idx) {
        if (idx < 0 || idx >= lbImages.length) return;
        if (!lastFocusedEl) lastFocusedEl = document.activeElement;
        lbIndex = idx;
        window.lbIndex = idx;
        lightboxImg.src = lbImages[idx].src;
        lightboxImg.alt = lbImages[idx].title;
        lightboxTitle.textContent = (idx + 1) + ' von ' + lbImages.length + ' – ' + lbImages[idx].title;
        updateLbMeta(lbImages[idx]);
        if (!lightbox.classList.contains('open')) {
          lightbox.classList.add('open');
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          setBackgroundInert(true);
        }
        updateLbArrows();
        lightboxClose.focus();
      }

      function updateLbArrows() {
        if (lbImages.length <= 1) {
          lightboxPrev.style.display = 'none';
          lightboxNext.style.display = 'none';
        } else {
          lightboxPrev.style.display = lbIndex > 0 ? 'flex' : 'none';
          lightboxNext.style.display = lbIndex < lbImages.length - 1 ? 'flex' : 'none';
        }
      }

      lightboxPrev.addEventListener('click', function (e) {
        e.stopPropagation();
        if (lbIndex > 0) showLbImage(lbIndex - 1);
      });

      lightboxNext.addEventListener('click', function (e) {
        e.stopPropagation();
        if (lbIndex < lbImages.length - 1) showLbImage(lbIndex + 1);
      });

      lightboxClose.addEventListener('click', function (e) {
        e.stopPropagation();
        closeLightbox();
      });

      lightbox.addEventListener('click', function (e) {
        if (e.target === lightbox) closeLightbox();
      });

      // Focus trap inside lightbox
      lightbox.addEventListener('keydown', function (e) {
        if (!lightbox.classList.contains('open')) return;
        if (e.key !== 'Tab') return;
        var allBtns = lightbox.querySelectorAll('button');
        var focusableArr = [];
        for (var b = 0; b < allBtns.length; b++) {
          if (allBtns[b].offsetParent !== null) focusableArr.push(allBtns[b]);
        }
        if (focusableArr.length === 0) return;
        var first = focusableArr[0];
        var last = focusableArr[focusableArr.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });

      // Touch swipe support for lightbox
      var touchStartX = 0;
      var touchStartY = 0;
      var touchId = null;

      lightbox.addEventListener('touchstart', function (e) {
        if (e.touches.length === 1) {
          touchId = e.touches[0].identifier;
          touchStartX = e.touches[0].screenX;
          touchStartY = e.touches[0].screenY;
        }
      }, { passive: true });

      lightbox.addEventListener('touchmove', function (e) {
        if (touchId !== null && lightbox.classList.contains('open')) {
          var touch = null;
          for (var t = 0; t < e.touches.length; t++) {
            if (e.touches[t].identifier === touchId) { touch = e.touches[t]; break; }
          }
          if (touch) {
            var dx = Math.abs(touch.screenX - touchStartX);
            var dy = Math.abs(touch.screenY - touchStartY);
            if (dx > dy) e.preventDefault();
          }
        }
      }, { passive: false });

      lightbox.addEventListener('touchend', function (e) {
        var touch = null;
        for (var t = 0; t < e.changedTouches.length; t++) {
          if (e.changedTouches[t].identifier === touchId) {
            touch = e.changedTouches[t];
            break;
          }
        }
        if (!touch) return;
        touchId = null;
        var dx = touch.screenX - touchStartX;
        var dy = touch.screenY - touchStartY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
          if (dx < 0 && lbIndex < lbImages.length - 1) {
            showLbImage(lbIndex + 1);
          } else if (dx > 0 && lbIndex > 0) {
            showLbImage(lbIndex - 1);
          }
        }
      }, { passive: true });

      document.addEventListener('keydown', function (e) {
        if (lightbox.classList.contains('open')) {
          if (e.key === 'Escape') { closeLightbox(); return; }
          if (e.key === 'ArrowRight' && lbIndex < lbImages.length - 1) { showLbImage(lbIndex + 1); return; }
          if (e.key === 'ArrowLeft' && lbIndex > 0) { showLbImage(lbIndex - 1); return; }
        } else if (e.key === 'Escape' && nav.classList.contains('open')) {
          closeMenu();
          burger.focus();
        }
      });

      // Expose globally for [slug].astro
      window.openLightbox = openLightbox;
      window.lbImages = lbImages;
      window.lbIndex = lbIndex;
      window.showLbImage = showLbImage;
      window.setLbImages = function (images) { lbImages = images; window.lbImages = images; };
      window.setLbIndex = function (idx) { lbIndex = idx; window.lbIndex = idx; };

      // CRITICAL FIX: pick up images stashed by [slug].astro if it ran first
      if (window._pendingLbImages) {
        lbImages = window._pendingLbImages;
        window.lbImages = lbImages;
        delete window._pendingLbImages;
      }

      function initNetlifyIdentity() {
        if (window.netlifyIdentity) {
          window.netlifyIdentity.on('init', function (user) {
            if (!user) {
              window.netlifyIdentity.on('login', function () {
                document.location.href = '/admin/';
              });
            }
          });
        }
      }
      initNetlifyIdentity();
      window.addEventListener('netlifyIdentityReady', initNetlifyIdentity);
    })();
  </script>

</body>
</html>
